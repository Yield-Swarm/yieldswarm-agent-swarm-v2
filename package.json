{
  "name": "yieldswarm-agentswarm-os",
  "version": "2.0.0",
  "private": true,
  "description": "YieldSwarm v2 monorepo — payments, integration backend, and agent swarm",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build && npm run build:frontend",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "node --test frontend/tests/*.test.js",
    "test:backend": "cd backend && npm test",
    "test:python": "python3 -m unittest discover -s tests -p 'test_*.py'"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.3",
    "@tonconnect/sdk": "^3.0.5",
    "@tonconnect/ui-react": "^2.0.9",
    "ethers": "^6.13.2",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "square": "^37.0.0",
    "viem": "^2.21.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
