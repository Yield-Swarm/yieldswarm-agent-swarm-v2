{
  "name": "yieldswarm-agentswarm-os",
  "version": "2.0.0",
  "private": true,
  "description": "YieldSwarm v2 — payments (Stripe/Square/Wise/Web3), Kairo, Akash, Odysseus integration backend",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build && npm run build:frontend",
    "test": "vitest run && npm run test:frontend && npm run test:backend",
    "test:unit": "vitest run",
    "test:entropy": "vitest run src/infrastructure/entropy-core.test.js src/infrastructure/entropy-circuit-inputs.test.js",
    "test:helix": "vitest run src/infrastructure/helix-phase1.test.js",
    "circuits:build": "cd circuits && npm run build",
    "deploy:render": "bash deploy/templates/lib/render-template.sh all",
    "deploy:stack": "bash deploy/deploy-full-stack.sh",
    "test:frontend": "node --test frontend/tests/*.test.js",
    "test:backend": "cd backend && npm test",
    "test:integration": "bash tests/integration/smoke_test.sh",
    "test:python": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "run-all-onchain": "bash scripts/run-all-onchain.sh",
    "prod": "npm run build:all && npm start",
    "prod:backend": "cd backend && npm start",
    "prod:helix": "bash scripts/activate-helix.sh",
    "prod:mining": "bash scripts/mining/start-all.sh",
    "cherry:export-specs": "bash scripts/cherry-servers/export-cloud-specs.sh --load-vault",
    "trident:wire-domains": "npx tsx scripts/wire-domains.ts",
    "trident:deploy": "bash scripts/launch-trident-mainnet.sh",
    "trident:deploy:dry": "bash scripts/launch-trident-mainnet.sh --dry-run",
    "trident:loops": "bash scripts/start-trident-loops.sh",
    "azure:wire-ssh": "bash scripts/azure/wire-ssh-key.sh",
    "azure:vmss-mining": "bash scripts/azure/deploy-vmss-mining.sh",
    "termux:dev": "bash scripts/termux/launch-openclaws-dev.sh",
    "termux:backend": "npm run prod:backend",
    "mining:tandem": "bash scripts/mining/tandem-pow-launch.sh",
    "depin:vehicle-edge": "node services/depin/vehicle-edge.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@solana/web3.js": "^1.95.3",
    "@stripe/react-stripe-js": "^2.8.0",
    "@stripe/stripe-js": "^4.5.0",
    "@telegram-apps/analytics": "^1.6.4",
    "@tonconnect/sdk": "^3.0.5",
    "@tonconnect/ui-react": "^2.0.9",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.13.2",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "square": "^37.0.0",
    "stripe": "^16.12.0",
    "viem": "^2.21.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "circomlibjs": "^0.1.7",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.39",
    "snarkjs": "^0.7.5",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
