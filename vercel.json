{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "package.json", "use": "@vercel/next" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "sales.html", "use": "@vercel/static" },
    { "src": "marketplace.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "integrations/**", "use": "@vercel/static" },
    { "src": "council/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/.well-known/appspecific/com.tesla.3p.public-key.pem", "dest": "/public/.well-known/appspecific/com.tesla.3p.public-key.pem" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/integrations/(.*)", "dest": "/integrations/$1" },
    { "src": "/sales", "dest": "/sales.html" },
    { "src": "/marketplace", "dest": "/marketplace.html" },
    { "src": "/dashboard/(.*)", "dest": "/dashboard/$1" },
    { "src": "/kairo", "dest": "/kairo/frontend/index.html" },
    { "src": "/kairo/(.*)", "dest": "/kairo/frontend/$1" },
    { "src": "/dashboard/(.*)", "dest": "/dashboard/$1" },
    { "src": "/api/revenue/(.*)", "dest": "/src/app/api/revenue/$1" },
    { "src": "/api/helix/(.*)", "dest": "/src/app/api/helix/$1" },
    { "src": "/api/(.*)", "dest": "/src/app/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/src/app/$1" }
  ],
  "env": {
    "KAIRO_API_BASE": "@kairo_api_base",
    "MAPBOX_TOKEN": "@mapbox_token"
  }
}
