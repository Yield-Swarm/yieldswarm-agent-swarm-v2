{
  "mcpServers": {
    "yieldswarm": {
      "command": "python3",
      "args": ["mcp_servers/yieldswarm_server.py"],
      "cwd": "${workspaceFolder}",
      "env": {
        "VAULT_ADDR": "${env:VAULT_ADDR}",
        "YIELDSWARM_DRY_RUN": "true"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "cwd": "${workspaceFolder}"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "time": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-time"]
    },
    "linear": {
      "command": "npx",
      "args": ["-y", "linear-mcp-server"],
      "env": {
        "LINEAR_API_KEY": "${env:LINEAR_API_KEY}"
      }
    },
    "stripe": {
      "command": "npx",
      "args": ["-y", "@stripe/mcp@0.1.0"],
      "env": {
        "STRIPE_SECRET_KEY": "${env:STRIPE_SECRET_KEY}"
      }
    },
    "aws": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-aws-kb-retrieval"],
      "env": {
        "AWS_ACCESS_KEY_ID": "${env:AWS_ACCESS_KEY_ID}",
        "AWS_SECRET_ACCESS_KEY": "${env:AWS_SECRET_ACCESS_KEY}",
        "AWS_REGION": "${env:AWS_REGION}"
      }
    },
    "azure": {
      "command": "npx",
      "args": ["-y", "@azure/mcp@latest"],
      "env": {
        "AZURE_CLIENT_ID": "${env:AZURE_CLIENT_ID}",
        "AZURE_CLIENT_SECRET": "${env:AZURE_CLIENT_SECRET}",
        "AZURE_TENANT_ID": "${env:AZURE_TENANT_ID}",
        "AZURE_SUBSCRIPTION_ID": "${env:AZURE_SUBSCRIPTION_ID}"
      }
    },
    "grafana-cloud": {
      "command": "npx",
      "args": ["-y", "@grafana/mcp-grafana"],
      "env": {
        "GRAFANA_URL": "${env:GRAFANA_URL}",
        "GRAFANA_API_KEY": "${env:GRAFANA_API_KEY}"
      }
    },
    "render": {
      "url": "https://api.render.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:RENDER_API_KEY}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "${env:DATABASE_URL}"],
      "disabled": true,
      "comment": "Enable when DATABASE_URL (Neon) is set"
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${env:BRAVE_API_KEY}"
      },
      "disabled": true,
      "comment": "Enable with BRAVE_API_KEY for provider doc search"
    }
  },
  "_meta": {
    "description": "YieldSwarm unified MCP config (god-prompt-swarm + multicloud)",
    "setup": "docs/CURSOR_CLOUD_SETUP.md",
    "linear": "Authenticate Linear via Cursor IDE MCP panel (not in this file)",
    "vault_paths": {
      "runpod": "kv/yieldswarm/cloud/runpod",
      "vast": "kv/yieldswarm/cloud/vast",
      "azure": "kv/yieldswarm/cloud/azure",
      "gcp": "kv/yieldswarm/cloud/gcp",
      "akash": "kv/yieldswarm/cloud/akash",
      "tesla": "kv/yieldswarm/integrations/tesla"
    }
  }
}
