FROM python:3.12-slim

WORKDIR /app
COPY requirements-swarm.txt .
RUN pip install --no-cache-dir -r requirements-swarm.txt

COPY swarms/ /app/swarms/
COPY schemas/ /app/schemas/
COPY agents/system/manifests/deities/ /app/agents/system/manifests/deities/
COPY dashboard/ /app/dashboard/

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

CMD ["python3", "-m", "swarms.helical.coordinator"]
