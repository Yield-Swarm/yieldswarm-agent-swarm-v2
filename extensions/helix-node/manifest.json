{
  "manifest_version": 3,
  "name": "Helix Nodes by YieldSwarm",
  "version": "0.1.0",
  "description": "Run a lightweight Helix node in the background. Earn lottery tickets while you browse.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "http://127.0.0.1:8080/*",
    "http://localhost:8080/*",
    "https://*.yieldswarm.network/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Helix Nodes",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
