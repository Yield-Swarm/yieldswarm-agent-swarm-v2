{{/*
  apn.env.tmpl -- rendered by Vault Agent into /run/apn/secrets/apn.env.
  The entrypoint sources this file with `set -a; . apn.env; set +a` so
  every variable becomes an env var for the swarm process.

  Naming intentionally mirrors .env.example so the existing agents work
  unchanged. Values come exclusively from Vault KV v2 at the apn/* prefix.
*/}}

{{- with secret (printf "%s/data/%s/core" (env "VAULT_KV_MOUNT") (env "VAULT_SECRET_PREFIX")) }}
AGENTSWARM_MASTER_KEY={{ .Data.data.master_key }}
KIMICLAW_CONSENSUS_KEY={{ .Data.data.kimiclaw_consensus_key }}
WALLET_ENCRYPTION_KEY={{ .Data.data.wallet_encryption_key }}
TEE_SIGNING_KEY={{ .Data.data.tee_signing_key }}
DATABASE_ENCRYPTION_KEY={{ .Data.data.database_encryption_key }}
{{- end }}

{{- with secret (printf "%s/data/%s/llm/openai" (env "VAULT_KV_MOUNT") (env "VAULT_SECRET_PREFIX")) }}
OPENAI_API_KEY={{ .Data.data.api_key }}
