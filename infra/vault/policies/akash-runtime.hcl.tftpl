# Akash runtime may read only its runtime configuration and RPC endpoints.
path "${kv_mount_path}/data/akash/runtime" {
  capabilities = ["read"]
}

path "${kv_mount_path}/metadata/akash/runtime" {
  capabilities = ["read"]
}

path "${kv_mount_path}/data/rpc" {
  capabilities = ["read"]
}

path "${kv_mount_path}/metadata/rpc" {
  capabilities = ["read"]
}

path "${transit_mount_path}/encrypt/akash-env" {
  capabilities = ["update"]
}

path "${transit_mount_path}/decrypt/akash-env" {
  capabilities = ["update"]
}

path "auth/token/lookup-self" {
  capabilities = ["read"]
}

path "auth/token/renew-self" {
  capabilities = ["update"]
}
