%{ for path in secret_paths ~}
path "${kv_mount_path}/data/${path}" {
  capabilities = ["read"]
}

path "${kv_mount_path}/metadata/${path}" {
  capabilities = ["read", "list"]
}

%{ endfor ~}
path "auth/token/lookup-self" {
  capabilities = ["read"]
}

path "auth/token/renew-self" {
  capabilities = ["update"]
}
