# Copy to secrets.env (which is .gitignored) and fill in real values, then:
#   set -a; source ./secrets.env; set +a
#   ./seed-secrets.sh
#
# Only variables you set are written to Vault; leave the rest blank to skip.

# --- Azure service principal (Terraform: azurerm) ---------------------------
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=
ARM_TENANT_ID=
ARM_SUBSCRIPTION_ID=

# --- RunPod (Terraform: runpod) ---------------------------------------------
RUNPOD_API_KEY=

# --- Vultr (Terraform: vultr) -----------------------------------------------
VULTR_API_KEY=

# --- DigitalOcean (Terraform: digitalocean) ---------------------------------
DIGITALOCEAN_TOKEN=

# --- Blockchain / RPC (Terraform AND Akash runtime) -------------------------
SOLANA_RPC_URL=
HELIUS_API_KEY=
BIRDEYE_API_KEY=
JUPITER_API_KEY=
RAYDIUM_API_KEY=
TON_API_KEY=
TAO_SUBNET_KEY=
FAILOVER_RPC_LIST=

# --- Application runtime bundle (Akash runtime) -----------------------------
AGENTSWARM_MASTER_KEY=
KIMICLAW_CONSENSUS_KEY=
GROK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
WALLET_ENCRYPTION_KEY=
TEE_SIGNING_KEY=
DATABASE_ENCRYPTION_KEY=
TELEGRAM_BOT_TOKEN=
GITHUB_TOKEN=
NOTION_API_KEY=
LINEAR_API_KEY=
VERCEL_API_TOKEN=
PUMP_FUN_DEPLOY_KEY=
