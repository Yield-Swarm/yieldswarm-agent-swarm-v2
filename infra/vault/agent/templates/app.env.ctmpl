{{- /* Rendered to /run/vault-agent/app.env (tmpfs, mode 0400). */ -}}
{{- $env := env "YS_ENV" | default "prod" -}}
{{- $base := printf "kv/data/yieldswarm/%s" $env -}}

{{- with secret (printf "%s/app/agentswarm" $base) }}
{{- range $k, $v := .Data.data }}
{{ $k | toUpper }}={{ $v }}
{{- end }}
{{- end }}

{{- with secret (printf "%s/rpc/solana" $base) }}
SOLANA_RPC_URL={{ .Data.data.url }}
HELIUS_API_KEY={{ .Data.data.helius_api_key }}
JUPITER_API_KEY={{ .Data.data.jupiter_api_key }}
BIRDEYE_API_KEY={{ .Data.data.birdeye_api_key }}
RAYDIUM_API_KEY={{ .Data.data.raydium_api_key }}
{{- end }}

{{- with secret (printf "%s/rpc/eth" $base) }}
ETH_MAINNET_RPC_URL={{ .Data.data.mainnet_url }}
ETH_SEPOLIA_RPC_URL={{ .Data.data.sepolia_url }}
ERC4337_BUNDLER_URL={{ .Data.data.bundler_url }}
{{- end }}

{{- with secret (printf "%s/rpc/ton" $base) }}
TON_RPC_URL={{ .Data.data.url }}
TON_API_KEY={{ .Data.data.api_key }}
{{- end }}

{{- with secret (printf "%s/rpc/tao" $base) }}
TAO_RPC_URL={{ .Data.data.url }}
TAO_SUBNET_KEY={{ .Data.data.subnet_key }}
{{- end }}

{{- with secret (printf "%s/akash" $base) }}
AKASH_WALLET_MNEMONIC={{ .Data.data.wallet_mnemonic }}
AKASH_KEYRING_PASSPHRASE={{ .Data.data.keyring_passphrase }}
AKASH_PROVIDER_URI={{ .Data.data.provider_uri }}
AKASH_CHAIN_ID={{ .Data.data.chain_id }}
{{- end }}
