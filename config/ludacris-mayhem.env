# Ludacris Mayhem Mode — live wire flags (no secrets)
# Source before: ./scripts/ludacris-mayhem-live.sh
# Full treasury live requires explicit: LUDACRIS_TREASURY_LIVE=1

LUDACRIS_MAYHEM_MODE=1
MAYHEM_MODE_ENABLED=true
ZK_MAYHEM_ENABLED=1
ZK_MIN_ENTROPY_QUALITY=0.5

# Solenoids live
NEXUS_BUS_URL=
NETWORK_LOCKDOWN_MODE=false

# Cross-chain / treasury — stay dry unless treasury live flag set
CROSS_CHAIN_DRY_RUN=1
CROSS_CHAIN_MVP_ENABLED=true
MUTATION_ENGINE_DRY_RUN=1

# Helix + Shadow live telemetry
HELIX_CHAIN_ENABLED=true

# Command dashboard poll
YIELDSWARM_POLL_MS=10000

# API target (override on VM)
API_BASE=http://127.0.0.1:8080
