# ============================================
# YIELDSWARM — LAYERED ENVIRONMENT VARIABLES
# ============================================
# Copy: cp config/env/.env.layered.example .env
# Canonical full catalog: .env.example + docs/ENV_VARS.md
# Production: prefer Vault injection (docs/VAULT_ENV_INJECTION.md)
# Never commit real secrets.

# --- D¹ Greek Layer (Security & Isolation) ---
GREEK_LAYER__ACCESS_CONTROL_ENABLED=true
GREEK_LAYER__MAX_CONTEXT_WINDOW=32
GREEK_LAYER__STRICT_SANITIZATION=true
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=
AGENTSWARM_MASTER_KEY=
WALLET_ENCRYPTION_KEY=
TEE_SIGNING_KEY=
DATABASE_ENCRYPTION_KEY=

# --- E¹ Eastern Layer (Flow & Feedback) ---
EASTERN_LAYER__FEEDBACK_ENABLED=true
EASTERN_LAYER__RECURSIVE_ROUTING=true
SOVEREIGN_LOOP_INTERVAL=900
SOVEREIGN_ONESHOT=0
GREAT_DELTA_INGEST_URL=http://127.0.0.1:8080/api/great-delta/telemetry

# --- O¹ Helix Oscillator (Scheduling & Timing) ---
ZK_MUTATION_INTERVAL_MS=604800000
ZK_MIN_ENTROPY_QUALITY=0.5
ZK_MAYHEM_ENABLED=1
MUTATION_WEBHOOK_URL=http://127.0.0.1:8080/api/oracle/sync
CLOUD_SCHEDULER_WEEK=1
MANDELBROT_BOT_INTERVAL=60
MANDELBROT_BOT_DRIVER_ID=mandelbrot-bot-001

# --- ZK¹ Entropy Layer ---
ZK__CIRCUIT_WASM=./circuits/build/entropy_proof_js/entropy_proof.wasm
ZK__ZKEY_PATH=./circuits/build/entropy_proof_final.zkey
ZK__VERIFIER_ADDRESS=
MUTATION_CONTROLLER_ADDRESS=
YIELDSWARM_NFT_ADDRESS=
NEON_LOG_ENABLED=true
NEON_FALLBACK_DIR=.data/neon
NEON_AUTO_MIGRATE=true

# --- Helix Chain + Cross-Execution ---
HELIX_CHAIN_ENABLED=0
HELIX_CHAIN_BRIDGE_KEY=
YIELDSWARM_HELIX_EMISSION_ROUTER=
HELIX_CONTROL_PLANE_URL=
TF_CLOUD_ORGANIZATION=HelixChainProd
TF_WORKSPACE=Helixchainprod

# --- LLM Routing Layer (Odysseus + LiteLLM) ---
LLM__ROUTER_TYPE=odysseus
LLM__DEFAULT_MODEL=llama3.1:8b
LLM_ROUTER_BIND=127.0.0.1
LLM_ROUTER_PORT=4000
YIELDSWARM_ROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
AKASH_OLLAMA_BASE_URL=http://akash-ollama-worker.internal:11434
AKASH_OLLAMA_MODEL=llama3.1:8b
LOCAL_OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Multi-Cloud Infrastructure (18 providers) ---
# Akash
AKASH_OWNER_ADDRESS=
AKASH_KEY_NAME=
AKASH_NODE=https://rpc.akash.network:443
AKASH_CHAIN_ID=akashnet-2
# Optional GPU clouds
RUNPOD_API_KEY=
VAST_API_KEY=
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
MULTICLOUD_DAILY_BUDGET_USD=50

# --- TON + Kairo Layer ---
TONCENTER_API_KEY=
TON_MINI_APP_URL=
KAIRO_API_URL=http://127.0.0.1:8100
KAIRO_PUBLIC_API_BASE=/api/kairo
KAIRO_STORE_DIR=.data/kairo
KAIRO_DEPIN_REWARD_RATE=0.02
VITE_KAIRO_API_URL=http://127.0.0.1:8100
VITE_MAPBOX_TOKEN=

# --- Database & Storage ---
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
NEON_PROJECT_ID=
IPFS_API_KEY=
ARWEAVE_KEY=

# --- Arena + Telemetry ---
YIELDSWARM_API_BASE=http://127.0.0.1:8080/api
VITE_ARENA_OVERVIEW_URL=/api/arena/overview
AKASH_LEASES_URL=
TREASURY_VELOCITY_URL=

# --- Blockchain / Payments ---
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=
INFURA_API_KEY=
STRIPE_SECRET_KEY=
SQUARE_ACCESS_TOKEN=

# --- Monitoring & Observability ---
SENTRY_DSN=
PROMETHEUS_URL=http://127.0.0.1:9090
GRAFANA_URL=http://127.0.0.1:3001

# --- Edge / Domains (17-domain mesh) ---
APP_URL=https://yieldswarm.crypto
NEXT_PUBLIC_APP_URL=https://yieldswarm.crypto
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
