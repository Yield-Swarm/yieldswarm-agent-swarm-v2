# Multi-cloud daily budget caps (copy to budgets.env — never commit real values)
# Source before launch: source config/multicloud/budgets.env

MULTICLOUD_DAILY_BUDGET_USD=50
MULTICLOUD_AKASH_MAX_AKT=5
MULTICLOUD_RUNPOD_MAX_USD=200
MULTICLOUD_VAST_MAX_USD=150
MULTICLOUD_AZURE_MAX_USD=300
MULTICLOUD_GCP_MAX_USD=300
MULTICLOUD_AWS_MAX_USD=200
MULTICLOUD_ALIBABA_MAX_USD=100

# Alert threshold (% of daily budget)
MULTICLOUD_ALERT_PCT=80
