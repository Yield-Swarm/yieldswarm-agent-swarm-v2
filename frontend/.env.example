# YieldSwarm frontend — wallet layer configuration.
# Copy to `.env` and fill in. All values are optional; sensible public defaults
# are used when unset. Only VITE_*-prefixed variables are exposed to the client.

# App identity (shown in wallet connect prompts / TonConnect)
VITE_APP_NAME="YieldSwarm v2"
VITE_APP_URL="https://yieldswarm.app"

# WalletConnect / Reown project id — enables EVM QR + mobile deep-link wallets.
# Get one free at https://cloud.reown.com. Without it only injected (extension)
# EVM wallets are offered.
VITE_WALLETCONNECT_PROJECT_ID=""

# EVM RPC endpoints (defaults to public llamarpc endpoints)
VITE_EVM_RPC_ETHEREUM="https://eth.llamarpc.com"
VITE_EVM_RPC_POLYGON="https://polygon.llamarpc.com"
VITE_EVM_RPC_BASE="https://base.llamarpc.com"
VITE_EVM_RPC_ARBITRUM="https://arbitrum.llamarpc.com"

# Solana RPC (a dedicated Helius/Triton endpoint is recommended for production)
VITE_SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

# TonConnect manifest URL (must be publicly reachable). A default manifest is
# served from /tonconnect-manifest.json.
VITE_TON_MANIFEST_URL=""

# Bitcoin REST API for read-only balance/UTXO lookups
VITE_BITCOIN_API_URL="https://mempool.space/api"
