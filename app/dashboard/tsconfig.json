{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@yieldswarm/cross-chain-sdk": ["../../packages/cross-chain-sdk/src/index.ts"],
      "@yieldswarm/cross-chain-sdk/*": ["../../packages/cross-chain-sdk/src/*"]
    }
  },
  "include": ["src"]
}
