# =============================================================================
# .gitignore — YieldSwarm AgentSwarm OS v2.0
# =============================================================================

# -----------------------------------------------------------------------
# VAULT — NEVER COMMIT THESE
# -----------------------------------------------------------------------
vault-init.json
role-ids.env
secret-ids.env
vault/setup/06-seed-secrets.local.sh
vault/setup/*.local.sh
/tmp/akash-deploy.yaml

# Vault data and logs (runtime state)
vault/data/
vault/logs/
vault/auth/.token

# -----------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfvars        # use terraform.tfvars.example instead
terraform/*.tfplan
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/crash.log

# -----------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
.env                              # never commit real .env files

# -----------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------
docker/requirements-lock.txt

# -----------------------------------------------------------------------
# OS / editor noise
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.log
