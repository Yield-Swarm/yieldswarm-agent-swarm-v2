{{- with secret (printf "%s/data/providers/azure" (env "VAULT_KV_MOUNT" | or "yieldswarm")) }}
AZURE_CLIENT_ID={{ .Data.data.client_id | toJSON }}
AZURE_CLIENT_SECRET={{ .Data.data.client_secret | toJSON }}
AZURE_TENANT_ID={{ .Data.data.tenant_id | toJSON }}
AZURE_SUBSCRIPTION_ID={{ .Data.data.subscription_id | toJSON }}
{{- end }}

{{- with secret (printf "%s/data/runtime/nexus" (env "VAULT_KV_MOUNT" | or "yieldswarm")) }}
NEXUS_COORDINATOR_KEY={{ .Data.data.coordinator_key | toJSON }}
VAULT_INJECT_PROVIDER=azure
{{- end }}

{{- with secret (printf "%s/data/runtime/core" (env "VAULT_KV_MOUNT" | or "yieldswarm")) }}
AGENTSWARM_MASTER_KEY={{ .Data.data.agentswarm_master_key | toJSON }}
{{- end }}
