{{- with secret (printf "%s/data/providers/vastai" (env "VAULT_KV_MOUNT" | or "yieldswarm")) }}
VASTAI_API_KEY={{ .Data.data.api_key | toJSON }}
VASTAI_USER_ID={{ .Data.data.user_id | toJSON }}
{{- end }}

{{- with secret (printf "%s/data/runtime/helix" (env "VAULT_KV_MOUNT" | or "yieldswarm")) }}
HELIX_CHAIN_BRIDGE_KEY={{ .Data.data.bridge_key | toJSON }}
IOTEX_ROUTING_ENABLED={{ .Data.data.iotex_routing_enabled | toJSON }}
{{- end }}

{{- with secret (printf "%s/data/runtime/zk" (env "VAULT_KV_MOUNT" | or "yieldswarm")) }}
ZK__VERIFIER_ADDRESS={{ .Data.data.verifier_address | toJSON }}
MUTATION_CONTROLLER_ADDRESS={{ .Data.data.mutation_controller | toJSON }}
{{- end }}

{{- with secret (printf "%s/data/runtime/wallets" (env "VAULT_KV_MOUNT" | or "yieldswarm")) }}
HELIX_CHAIN_BRIDGE_KEY={{ .Data.data.helix_chain_bridge_key | toJSON }}
{{- end }}
