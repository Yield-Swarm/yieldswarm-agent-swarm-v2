# Solenoid-aware secret paths for {{ env "PROVIDER" | or "akash" }}

{{- with secret (printf "%s/data/runtime/akash" (env "VAULT_KV_MOUNT" | or "yieldswarm")) }}
AKASH_OWNER_ADDRESS={{ .Data.data.owner_address | toJSON }}
AKASH_KEY_NAME={{ .Data.data.key_name | toJSON }}
{{- end }}

{{- with secret (printf "%s/data/runtime/nexus" (env "VAULT_KV_MOUNT" | or "yieldswarm")) }}
NEXUS_COORDINATOR_KEY={{ .Data.data.coordinator_key | toJSON }}
NEXUS_AGENT_CAP={{ .Data.data.agent_cap | toJSON }}
{{- end }}

{{- with secret (printf "%s/data/rpc/solana" (env "VAULT_KV_MOUNT" | or "yieldswarm")) }}
SOLANA_RPC_URL={{ .Data.data.url | toJSON }}
HELIUS_API_KEY={{ .Data.data.helius_api_key | toJSON }}
{{- end }}

{{- with secret (printf "%s/data/runtime/backend" (env "VAULT_KV_MOUNT" | or "yieldswarm")) }}
EMISSION_ROUTER_ADDRESS={{ .Data.data.emission_router_address | toJSON }}
TREASURY_ADDRESS={{ .Data.data.treasury_address | toJSON }}
{{- end }}
