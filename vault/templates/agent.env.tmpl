{{- /*
  Vault Agent secret template — YieldSwarm AgentSwarm OS v2.0
  Destination: /vault/secrets/agent.env
  Source this file in your application before reading environment variables.

  Secret mount: KV v2 at path "secret/"
  Path convention: secret/data/yieldswarm/<VAULT_ENVIRONMENT>/<category>/<name>

  All {{ }} blocks are rendered by Vault Agent; the resulting file contains
  only plain KEY=VALUE lines — no Vault syntax is ever written to disk.
*/ -}}

{{- $env := (env "VAULT_ENVIRONMENT") -}}
{{- if eq $env "" }}{{ $env = "production" }}{{ end -}}

# ---------------------------------------------------------------------------
# Core Agent Secrets
# ---------------------------------------------------------------------------
{{ with secret (printf "secret/data/yieldswarm/%s/agents/core" $env) -}}
export AGENTSWARM_MASTER_KEY="{{ .Data.data.master_key }}"
export KIMICLAW_CONSENSUS_KEY="{{ .Data.data.kimiclaw_consensus_key }}"
export WALLET_ENCRYPTION_KEY="{{ .Data.data.wallet_encryption_key }}"
export TEE_SIGNING_KEY="{{ .Data.data.tee_signing_key }}"
export DATABASE_ENCRYPTION_KEY="{{ .Data.data.database_encryption_key }}"
{{- end }}

# ---------------------------------------------------------------------------
# LLM / AI Provider Keys
# ---------------------------------------------------------------------------
{{ with secret (printf "secret/data/yieldswarm/%s/llm/providers" $env) -}}
export GROK_API_KEY="{{ .Data.data.grok_api_key }}"
export OPENAI_API_KEY="{{ .Data.data.openai_api_key }}"
export GEMINI_API_KEY="{{ .Data.data.gemini_api_key }}"
export ANTHROPIC_API_KEY="{{ .Data.data.anthropic_api_key }}"
export QUARANTINED_LLM_ARENA_KEY="{{ .Data.data.arena_key }}"
{{- end }}

# ---------------------------------------------------------------------------
# Solana / Blockchain RPC
# ---------------------------------------------------------------------------
{{ with secret (printf "secret/data/yieldswarm/%s/rpc/solana" $env) -}}
export SOLANA_RPC_URL="{{ .Data.data.primary_url }}"
export HELIUS_API_KEY="{{ .Data.data.helius_api_key }}"
export BIRDEYE_API_KEY="{{ .Data.data.birdeye_api_key }}"
export JUPITER_API_KEY="{{ .Data.data.jupiter_api_key }}"
export RAYDIUM_API_KEY="{{ .Data.data.raydium_api_key }}"
export FAILOVER_RPC_LIST='{{ .Data.data.failover_list }}'
export DEXSCREENER_API="{{ .Data.data.dexscreener_api_key }}"
export SOLSCAN_API_KEY="{{ .Data.data.solscan_api_key }}"
{{- end }}

# ---------------------------------------------------------------------------
# Blockchain / On-Chain Keys
# ---------------------------------------------------------------------------
{{ with secret (printf "secret/data/yieldswarm/%s/blockchain/keys" $env) -}}
export PUMP_FUN_DEPLOY_KEY="{{ .Data.data.pump_fun_deploy_key }}"
export TON_API_KEY="{{ .Data.data.ton_api_key }}"
export TAO_SUBNET_KEY="{{ .Data.data.tao_subnet_key }}"
export HELIX_CHAIN_BRIDGE_KEY="{{ .Data.data.helix_bridge_key }}"
export ZEC_SHIELDED_KEY="{{ .Data.data.zec_shielded_key }}"
export ERC4337_BUNDLER_KEY="{{ .Data.data.erc4337_bundler_key }}"
export NG64_BITTENSOR_NODE_STAKING_KEY="{{ .Data.data.bittensor_staking_key }}"
{{- end }}

# ---------------------------------------------------------------------------
# DePIN Hardware
# ---------------------------------------------------------------------------
{{ with secret (printf "secret/data/yieldswarm/%s/depin/hardware" $env) -}}
export DEPIN_HELIUM_HOTSPOT_KEYS='{{ .Data.data.helium_hotspot_keys }}'
export GPU_CLUSTER_KEYS='{{ .Data.data.gpu_cluster_keys }}'
export GRASS_NODE_KEYS='{{ .Data.data.grass_node_keys }}'
export SMARTTHINGS_BRIDGE_TOKEN="{{ .Data.data.smartthings_bridge_token }}"
export UTILITY_API_KEY="{{ .Data.data.utility_api_key }}"
{{- end }}

# ---------------------------------------------------------------------------
# Productivity / CI Integrations
# ---------------------------------------------------------------------------
{{ with secret (printf "secret/data/yieldswarm/%s/integrations/productivity" $env) -}}
export NOTION_API_KEY="{{ .Data.data.notion_api_key }}"
export LINEAR_API_KEY="{{ .Data.data.linear_api_key }}"
export VERCEL_API_TOKEN="{{ .Data.data.vercel_api_token }}"
export GITHUB_TOKEN="{{ .Data.data.github_token }}"
export S_AND_P_API_KEY="{{ .Data.data.sp_api_key }}"
export FSD_DATA_FEED_KEY="{{ .Data.data.fsd_data_feed_key }}"
export TESLA_INTEGRATION_TOKEN="{{ .Data.data.tesla_integration_token }}"
{{- end }}

# ---------------------------------------------------------------------------
# Social / Marketing
# ---------------------------------------------------------------------------
{{ with secret (printf "secret/data/yieldswarm/%s/integrations/social" $env) -}}
export TELEGRAM_BOT_TOKEN="{{ .Data.data.telegram_bot_token }}"
export X_API_KEYS='{{ .Data.data.x_api_keys }}'
export META_ADS_TOKEN="{{ .Data.data.meta_ads_token }}"
{{- end }}

# ---------------------------------------------------------------------------
# Payments
# ---------------------------------------------------------------------------
{{ with secret (printf "secret/data/yieldswarm/%s/integrations/payments" $env) -}}
export UD_API_KEY="{{ .Data.data.ud_api_key }}"
export FILECOIN_STORAGE_KEY="{{ .Data.data.filecoin_storage_key }}"
{{- end }}

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
{{ with secret (printf "secret/data/yieldswarm/%s/monitoring/config" $env) -}}
export MONITORING_PROMETHEUS_URL="{{ .Data.data.prometheus_url }}"
export ERROR_WEBHOOK="{{ .Data.data.error_webhook }}"
export ZKML_VERIFIER_KEY="{{ .Data.data.zkml_verifier_key }}"
{{- end }}

# ---------------------------------------------------------------------------
# Non-secret runtime config (safe to put here; no Vault lookup needed)
# ---------------------------------------------------------------------------
export VAULT_ENVIRONMENT="{{ $env }}"
export LOG_LEVEL="${LOG_LEVEL:-INFO}"
export NETWORK_LOCKDOWN_MODE="${NETWORK_LOCKDOWN_MODE:-true}"
export AGENT_COUNT_TOTAL="${AGENT_COUNT_TOTAL:-10080}"
export AGENTS_PER_SHARD="${AGENTS_PER_SHARD:-84}"
export CRON_SHARD_COUNT="${CRON_SHARD_COUNT:-120}"
export CRON_INTERVAL_MINUTES="${CRON_INTERVAL_MINUTES:-15}"
export RATE_LIMIT_RPM="${RATE_LIMIT_RPM:-60}"
export TOKEN_BUDGET_DAILY="${TOKEN_BUDGET_DAILY:-1000000}"
