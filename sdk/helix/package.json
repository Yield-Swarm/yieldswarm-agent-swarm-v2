{
  "name": "@yieldswarm/helix-sdk",
  "version": "0.1.0",
  "description": "YieldSwarm Helix cross-chain bridge SDK (Solenoid 2)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/pdas.test.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.3",
    "bn.js": "^5.2.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "@types/react": "^18.3.10",
    "typescript": "^5.6.2",
    "tsx": "^4.19.0"
  },
  "files": [
    "dist",
    "src/idl"
  ]
}
