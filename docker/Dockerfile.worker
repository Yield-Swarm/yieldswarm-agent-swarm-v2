ARG PYTHON_VERSION=3.12

FROM python:${PYTHON_VERSION}-slim AS builder

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN python -m venv /opt/venv \
    && /opt/venv/bin/pip install --upgrade pip setuptools wheel

COPY requirements*.txt ./
RUN if [ -f requirements.txt ]; then /opt/venv/bin/pip install -r requirements.txt; fi

COPY . .
RUN if [ -f pyproject.toml ] || [ -f setup.py ]; then /opt/venv/bin/pip install .; fi

FROM python:${PYTHON_VERSION}-slim AS runtime

ENV PATH="/opt/venv/bin:${PATH}" \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    APP_HOME=/app

RUN apt-get update \
    && apt-get install -y --no-install-recommends tini curl ca-certificates bash \
    && rm -rf /var/lib/apt/lists/*

WORKDIR ${APP_HOME}

RUN groupadd --gid 10001 app \
    && useradd --uid 10001 --gid app --create-home --shell /bin/bash app

COPY --from=builder /opt/venv /opt/venv
COPY --from=builder /app /app
COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh

RUN chmod 0755 /usr/local/bin/entrypoint.sh \
    && mkdir -p /var/lib/yieldswarm /var/cache/yieldswarm /var/log/yieldswarm \
    && chown -R app:app ${APP_HOME} /var/lib/yieldswarm /var/cache/yieldswarm /var/log/yieldswarm

USER app

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=5 \
  CMD curl --fail --silent --show-error "http://127.0.0.1:${HEALTH_PORT:-8080}/healthz" || exit 1

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/entrypoint.sh"]
CMD ["python", "-m", "worker"]
