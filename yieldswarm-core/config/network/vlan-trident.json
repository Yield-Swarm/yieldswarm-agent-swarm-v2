{
  "version": "1.0.0",
  "profile": "trident-vlan-static",
  "immutable": true,
  "description": "Structural topology for ASUS ZenWiFi BE5000 Pro mesh + TP-Link PoE+ smart switches",
  "mesh": {
    "vendor": "ASUS",
