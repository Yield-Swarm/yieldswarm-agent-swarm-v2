    {
      "model": "TL-SG605P",
      "role": "depin-phone-farm",
      "poe": "PoE+",
      "vlans": [20]
    }
  ],
  "vlans": [
    {
      "id": 10,
      "name": "Airgapped Core Trading Matrix",
