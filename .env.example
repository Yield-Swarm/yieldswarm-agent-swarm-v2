# YieldSwarm AgentSwarm OS bootstrap example
# This file intentionally contains NO live credentials.
# Production secrets now live in HashiCorp Vault and are fetched at runtime.
# Exact Vault bootstrap and rotation commands are documented in SECRETS.md.

# ========================================
# NON-SECRET APPLICATION DEFAULTS
# ========================================
APP_ENV=production
LOG_LEVEL=INFO
NETWORK_LOCKDOWN_MODE=true
AGENT_COUNT_TOTAL=10080
AGENTS_PER_SHARD=84
AGENT_SHARD_ID=0
CRON_SHARD_COUNT=120
CRON_INTERVAL_MINUTES=15
RATE_LIMIT_RPM=60
TOKEN_BUDGET_DAILY=1000000
REFERRAL_BONUS_RATE=0.05
AGENT_REFERRAL_TARGET=10000
AD_CAMPAIGN_BUDGET=20
BACKUP_CRON_INTERVAL=1440

# ========================================
# AKASH / VAULT BOOTSTRAP
# ========================================
# These values are safe to template into deployment manifests.
# Do NOT put role_id, secret_id, API keys, or RPC tokens in git.
BOOTSTRAP_ENV_FILE=/run/secrets/.env
VAULT_ADDR=https://vault.example.com
VAULT_NAMESPACE=
VAULT_KV_MOUNT=apps
VAULT_SECRET_PATHS=yieldswarm/base,yieldswarm/akash
VAULT_SECRET_WAIT_SECONDS=300
VAULT_SECRET_WAIT_INTERVAL=5

# ========================================
# NON-SECRET STRATEGY / TUNING VALUES
# ========================================
APN_MINT_ADDRESS=8JC3My2QqsK4fyTC8Ki3SJ6YZQ4miavzmAt82K1Kpump
PUMP_FUN_COIN_ID=8JC3My2QqsK4fyTC8Ki3SJ6YZQ4miavzmAt82K1Kpump
SLIPPAGE_TOLERANCE=0.005
MAX_FEE_PERCENT=0.01
IMPERMANENT_LOSS_THRESHOLD=0.1
MAYHEM_MODE_ENABLED=true
BUG_BOUNTY_AGENT_ENABLED=true
IPFS_GATEWAY=https://ipfs.io

# ========================================
# REFERENCES ONLY
# ========================================
# Vercel deployment URLs are not credentials and may remain here for operator context.
VERCEL_DEPLOYMENT_1=https://v2-0-bay.vercel.app/
VERCEL_PROJECT=https://vercel.com/support-6930s-projects/v2-0/c64SWNEkWaF39C4GcjFPYoLxWgMg

# ========================================
# VAULT-ONLY SECRET CONTRACT
# ========================================
# Store these in Vault instead of .env files:
# - cloud/azure: subscription_id, tenant_id, client_id, client_secret
# - cloud/runpod: api_key
# - cloud/vultr: api_key
# - cloud/digitalocean: token
# - rpc/mainnet: solana_rpc_url, helius_api_key, birdeye_api_key, jupiter_api_key,
#   raydium_api_key, ton_api_key, tao_subnet_key, helix_chain_bridge_key,
#   zec_shielded_key, erc4337_bundler_key, failover_rpc_list
# - apps/yieldswarm/base: AGENTSWARM_MASTER_KEY, KIMICLAW_CONSENSUS_KEY,
#   OPENAI_API_KEY, ANTHROPIC_API_KEY, GEMINI_API_KEY, GROK_API_KEY,
#   WALLET_ENCRYPTION_KEY, TEE_SIGNING_KEY, DATABASE_ENCRYPTION_KEY
# - apps/yieldswarm/akash: AKASH_API_KEY, DEPIN_HELIUM_HOTSPOT_KEYS,
#   GPU_CLUSTER_KEYS, GRASS_NODE_KEYS, SMARTTHINGS_BRIDGE_TOKEN,
#   COLORADO_POWER_PERMIT_ID, UTILITY_API_KEY, NOTION_API_KEY, LINEAR_API_KEY,
#   VERCEL_API_TOKEN, GITHUB_TOKEN, S_AND_P_API_KEY, FSD_DATA_FEED_KEY,
#   TESLA_INTEGRATION_TOKEN, TELEGRAM_BOT_TOKEN, X_API_KEYS, META_ADS_TOKEN,
#   FILECOIN_STORAGE_KEY, MONITORING_PROMETHEUS_URL, ERROR_WEBHOOK,
#   ADMIN_ACCOUNT_SEGMENT, QUARANTINED_LLM_ARENA_KEY, ZKML_VERIFIER_KEY,
#   DEXSCREENER_API, SOLSCAN_API_KEY, EMAIL_SMTP_CONFIG,
#   NG64_BITTENSOR_NODE_STAKING_KEY, BITTENSOR_TRAINING_CONFIG,
#   UD_API_KEY, WISE_BUSINESS_EMAIL