# Integrations
NOTION_API_KEY=replace_me
LINEAR_API_KEY=replace_me
VERCEL_API_TOKEN=replace_me
GITHUB_TOKEN=replace_me
S_AND_P_API_KEY=replace_me
FSD_DATA_FEED_KEY=replace_me
TESLA_INTEGRATION_TOKEN=replace_me

# Trading & Yield
RATE_LIMIT_RPM=60
TOKEN_BUDGET_DAILY=1000000
