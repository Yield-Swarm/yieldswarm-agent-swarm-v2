# YieldSwarm AgentSwarm OS .env.example
# For 10,080 AI Agents across 120 Cron Jobs
# Kimiclaw Consensus Council + SuperGrok Strategy Layer
# Post-Polsia, Helix Chain + Hydrogen Particle Accelerated Shading Tree
# Local development only. Production secrets must come from HashiCorp Vault.
# See SECRETS.md for the production Vault + Terraform workflow.

# ========================================
# CRITICAL - Core Auth & Security (Rotate Regularly)
# ========================================
AGENTSWARM_MASTER_KEY=replace_me
KIMICLAW_CONSENSUS_KEY=replace_me
GROK_API_KEY=replace_me
OPENAI_API_KEY=replace_me
GEMINI_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me
WALLET_ENCRYPTION_KEY=replace_me
TEE_SIGNING_KEY=replace_me
DATABASE_ENCRYPTION_KEY=replace_me

# Vault bootstrap coordinates for local/dev smoke tests.
VAULT_ADDR=https://vault.example.com
VAULT_NAMESPACE=
VAULT_ROLE_ID=replace_me
VAULT_SECRET_ID=replace_me
VAULT_SECRET_PATHS=kv-platform/providers/runpod,kv-platform/providers/vultr,kv-platform/providers/digitalocean,kv-platform/rpc/shared,kv-runtime/application/common,kv-runtime/akash/optimizer

# ========================================
# CLOUD PROVIDERS (Vault-backed in production)
# ========================================
ARM_SUBSCRIPTION_ID=replace_me
ARM_TENANT_ID=replace_me
ARM_CLIENT_ID=replace_me
ARM_CLIENT_SECRET=replace_me
RUNPOD_API_KEY=replace_me
VULTR_API_KEY=replace_me
