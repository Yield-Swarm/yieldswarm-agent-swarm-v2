# YieldSwarm AgentSwarm OS runtime configuration example.
#
# Production secrets live in HashiCorp Vault only. Do not put provider tokens,
# private keys, mnemonics, RPC credentials, emails, or payment credentials in
# this file. See SECRETS.md for the exact Vault bootstrap and seeding commands.

# Vault cluster used by Terraform, Docker, and Akash workloads.
VAULT_ADDR=https://vault.example.com
VAULT_NAMESPACE=

# Akash deployment bootstrap values. VAULT_ROLE_ID is not secret. The wrapped
# SecretID is sensitive, one-use, short-lived, and must be generated at deploy
# time with the commands in SECRETS.md.
VAULT_ROLE_ID=replace-with-role-id-from-vault
VAULT_WRAPPED_SECRET_ID=replace-at-deploy-time-only
VAULT_AGENT_CONFIG=/etc/vault/agent-configs/akash-agent.hcl
VAULT_SECRETS_FILE=/vault/secrets/yieldswarm.json

# Non-sensitive runtime tuning.
LOG_LEVEL=INFO
AGENT_COUNT_TOTAL=10080
AGENTS_PER_SHARD=84
AGENT_SHARD_ID=0
CRON_SHARD_COUNT=120
CRON_INTERVAL_MINUTES=15
RATE_LIMIT_RPM=60
TOKEN_BUDGET_DAILY=1000000
NETWORK_LOCKDOWN_MODE=true