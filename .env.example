# --- Square (fiat deposits: card + ACH) ---
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=sandbox            # sandbox | production
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
SQUARE_WEBHOOK_URL=http://localhost:3000/api/webhooks/square
# Public (browser) Web Payments SDK config — enables the embedded card+ACH form.
NEXT_PUBLIC_SQUARE_APP_ID=your_square_application_id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox

# --- Wise (fiat payouts/transfers + inbound) ---
