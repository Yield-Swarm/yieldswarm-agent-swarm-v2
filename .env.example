# Immune Bug Bounty & Bittensor
BUG_BOUNTY_AGENT_ENABLED=true
NG64_BITTENSOR_NODE_STAKING_KEY=replace_me
BITTENSOR_TRAINING_CONFIG='{"model":"replace_me","epochs":10}'

# Unstoppable Domains & Payments
UD_API_KEY=replace_me
