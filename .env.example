WISE_PROFILE_ID=your_wise_profile_id
WISE_SANDBOX=true                     # true -> api.sandbox.transferwise.tech
# WISE_API_BASE=https://api.transferwise.com   # optional explicit override
# RSA public key Wise uses to sign webhook deliveries (PEM; \n allowed).
WISE_WEBHOOK_PUBLIC_KEY=

# --- Web3 RPC endpoints (use paid/dedicated RPCs in production) ---
EVM_RPC_URL_1=https://eth.llamarpc.com
EVM_RPC_URL_8453=https://mainnet.base.org
EVM_RPC_URL_137=https://polygon-rpc.com
EVM_RPC_URL_42161=https://arb1.arbitrum.io/rpc
# SOLANA_RPC_URL is reused from the Blockchain section above.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
TON_API_BASE=https://tonapi.io
# TON_API_KEY reused from the Blockchain section above.

# --- Treasury deposit addresses (where on-chain deposits are sent) ---
TREASURY_EVM_ADDRESS=
TREASURY_SOLANA_ADDRESS=
TREASURY_TON_ADDRESS=

# --- Hot wallets (off-ramp: withdrawals to user wallets) ---
HOT_WALLET_EVM_PRIVATE_KEY=
# Solana secret key as a JSON byte array ("[12,34,...]") or base64.
HOT_WALLET_SOLANA_SECRET_KEY=
ONCHAIN_MIN_CONFIRMATIONS=3

# Great Delta Emission Router — 50/30/15/5 treasury split (basis points)
SPLIT_CORE_BPS=5000
SPLIT_GROWTH_BPS=3000
SPLIT_INSURANCE_BPS=1500
SPLIT_OPS_BPS=500
EMISSION_ROUTER_ADDRESS=
EMISSION_ROUTER_EVM_ADDRESS=
EVM_RPC_URL=
EVM_ENABLED=0
GREAT_DELTA_INGEST_URL=http://127.0.0.1:8080/api/great-delta/telemetry
TREASURY_ADDRESS=

# --- TON Connect (frontend) ---
NEXT_PUBLIC_TONCONNECT_MANIFEST_URL=http://localhost:3000/tonconnect-manifest.json

# --- Telegram Mini Apps Analytics (tganalytics.xyz) ---
# SDK auth token from TON Builders (@DataChief_bot). Client-side by design, but
# treat as private: set the real value in Vercel/Secrets, never commit it.
NEXT_PUBLIC_TELEGRAM_ANALYTICS_TOKEN=your_telegram_analytics_token
# Analytics identifier entered in TON Builders (the bot's analytics project).
NEXT_PUBLIC_TELEGRAM_ANALYTICS_APP_NAME=yieldswarmprod

# ========================================
# Tesla Fleet API — Partner auth, keys, telemetry
# ========================================
# developer.tesla.com application credentials (Vault only — never commit secrets)
TESLA_CLIENT_ID=your_tesla_client_id
TESLA_CLIENT_SECRET=your_tesla_client_secret
# Root domain registered with Tesla (no https:// prefix; must match allowed_origins)
TESLA_DOMAIN=yieldswarm-agent-swarm-v2-51zx4tmk-support-6930s-projects.vercel.app
TESLA_REGION=na
# EC private key for vehicle commands + signed telemetry config (gitignored)
TESLA_PRIVATE_KEY_PATH=tesla/keys/private-key.pem
TESLA_KEY_DIR=tesla/keys
TESLA_SCOPE=openid vehicle_device_data vehicle_cmds vehicle_charging_cmds vehicle_specs
# Fleet Telemetry server (subdomain of TESLA_DOMAIN; mTLS WebSocket)
TESLA_TELEMETRY_HOSTNAME=telemetry.your-registered-domain.com
TESLA_TELEMETRY_PORT=443
TESLA_VEHICLE_COMMAND_PROXY=http://127.0.0.1:4443
# Set TESLA_CN=1 when registering China region via ./scripts/register-tesla-fleet.sh all

# ========================================
# Multi-Cloud 30-Day Utilization
# ========================================
# Copy budgets: cp config/multicloud/budgets.env.example config/multicloud/budgets.env
MULTICLOUD_DAILY_BUDGET_USD=50
RUNPOD_API_KEY=
VAST_API_KEY=
AZURE_SUBSCRIPTION_ID=
GOOGLE_APPLICATION_CREDENTIALS=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ========================================
# Neon Postgres — payments ledger + Mandelbrot / Helix telemetry
# ========================================
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
NEON_PROJECT_ID=your_neon_project_id
NEON_LOG_ENABLED=true
NEON_FALLBACK_DIR=.data/neon
NEON_AUTO_MIGRATE=true

# Mandelbrot bot — Kairo drive sim + Helix Chain snapshots → Neon
MANDELBROT_BOT_INTERVAL=60
MANDELBROT_BOT_DRIVER_ID=mandelbrot-bot-001
MANDELBROT_BOT_ONESHOT=0

# ========================================
# Kairo — Driver App + DePIN Telemetry
# ========================================
KAIRO_API_PORT=8100
KAIRO_API_URL=http://127.0.0.1:8100
KAIRO_IDENTITY_STORE=.data/kairo/identities
KAIRO_MANDELBROT_STORE=.data/kairo/mandelbrot
KAIRO_DEPIN_REWARD_RATE=0.02
KAIRO_CORS_ORIGINS=http://localhost:5174,http://localhost:3000
VITE_KAIRO_API_URL=http://127.0.0.1:8100
VITE_MAPBOX_TOKEN=your_mapbox_token_here
ODYSSEUS_CHROMA_URL=

# Vercel Deployments (Reference)
VERCEL_DEPLOYMENT_1=https://v2-0-bay.vercel.app/
VERCEL_PROJECT=https://vercel.com/support-6930s-projects/v2-0/c64SWNEkWaF39C4GcjFPYoLxWgMg

# Additional Sharded/Per-Cron Overrides (Example)
# CRON_SCHEDULE_001=0 */15 * * *
# ... up to CRON_SCHEDULE_120

# ========================================
# Azure Container Instances (core API)
# ========================================
AZURE_RESOURCE_GROUP=yieldswarm-rg
AZURE_LOCATION=eastus
AZURE_DNS_LABEL=yieldswarm-core
AZURE_CONTAINER_GROUP=yieldswarm-core
AZURE_CPU=4
AZURE_MEMORY_GB=16
BACKEND_IMAGE=ghcr.io/yieldswarm/yieldswarm-backend:latest

# Azure VM SSH (break-glass + dashboard VM access)
# Public key only — never commit private keys. Seed Vault: yieldswarm/providers/azure
AZURE_ADMIN_USERNAME=azureuser
AZURE_SSH_KEY_NAME=yieldswarm-deploy-key
# AZURE_SSH_PUBLIC_KEY=ssh-ed25519 AAAA... yieldswarm-azure
# AZURE_SSH_PUBLIC_KEY_FILE=~/.ssh/id_ed25519.pub
# DEPLOY_SSH_PUBLIC_KEY=   # shared with Vultr/DO multicloud
# AZURE_VM_NAME=yieldswarm-vm
# AZURE_VMSS_NAME=yieldswarm-az-vmss

# ========================================
# Single Pane of Glass — IoT, Team, Business
# ========================================
IOT_APPLE_TV_HOSTS=
IOT_FIRE_TV_HOSTS=
JACK_PROFIT_WALLET=
ZEEVE_PROFIT_WALLET=
MAGIC_LINK_MYRA_EMAIL=
MAGIC_LINK_JACK_EMAIL=
MAGIC_LINK_KYLE_EMAIL=
MAGIC_LINK_NICK_EMAIL=
MAGIC_LINK_ZEEV_EMAIL=
DUNE_API_KEY=
DUNE_DASHBOARD_NEXUS=
DUNE_DASHBOARD_HELIX=
DUNE_DASHBOARD_SHADOW=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_REALM_ID=
SHADOW_CHAIN_ENABLED=0
YSLR_PHASE=genesis
ATOMIC_PULSE_INTERVAL=900

# ========================================
# Deployment Notes
# - Vercel/Azure/Render: inject Vault coordinates only; keep API keys in Vault
# - Odysseus: deploy with scripts/deploy-production-odysseus.sh or Akash SDL
# - Security: load secrets from HashiCorp Vault, never log values
# - Test: Start with 1 shard (84 agents) before full 10k
# ========================================
# Terraform Cloud (TFC bootstrap from PR #3 — modular, optional)
# Workspace: HelixChainProd / Helixchainprod
# See deploy/terraform-tfc/ and docs/DEPLOYMENT_GUIDE.md
# ========================================
TF_CLOUD_ORGANIZATION=HelixChainProd
TF_WORKSPACE=Helixchainprod
