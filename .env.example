# YieldSwarm AgentSwarm OS .env.example
# For 10,080 AI Agents across 120 Cron Jobs
# Kimiclaw Consensus Council + SuperGrok Strategy Layer
# Post-Polsia, Helix Chain + Hydrogen Particle Accelerated Shading Tree
# Fill in values securely (TEE/air-gapped). Never commit real secrets.
# Use for Vercel, Azure, Render, or local MacBook deployment.

# ========================================
# HASHICORP VAULT - Secret Source of Truth
# ========================================
VAULT_ADDR=https://vault.example.com
VAULT_NAMESPACE=
VAULT_AUTH_METHOD=jwt
VAULT_JWT_AUTH_PATH=auth/jwt/login
VAULT_JWT_ROLE=yieldswarm-odysseus-runtime
VAULT_JWT_FILE=/var/run/secrets/akash/serviceaccount/token
VAULT_TOKEN_FILE=/run/secrets/vault-token
ODYSSEUS_RUNTIME_VAULT_PATH=kv/data/yieldswarm/odysseus/runtime
ODYSSEUS_DEPLOY_VAULT_PATH=kv/data/yieldswarm/odysseus/deploy

# ========================================
# CRITICAL - Core Auth & Security (Rotate Regularly)
# ========================================
AGENTSWARM_MASTER_KEY=your_master_key_here
KIMICLAW_CONSENSUS_KEY=your_kimiclaw_key_here
GROK_API_KEY=your_grok_api_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
WALLET_ENCRYPTION_KEY=your_wallet_encryption_key_here
TEE_SIGNING_KEY=your_tee_signing_key_here
DATABASE_ENCRYPTION_KEY=your_db_encryption_key_here

# ========================================
# Odysseus Workspace + Multi-LLM Router
# ========================================
# Odysseus is the default YieldSwarm interface for agent orchestration.
APP_BIND=127.0.0.1
APP_PORT=7000
AUTH_ENABLED=true
LOCALHOST_BYPASS=false
SECURE_COOKIES=false
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=change_me_before_first_boot
ODYSSEUS_INSTALL_OPTIONAL=false
ODYSSEUS_BUILD_CONTEXT=https://github.com/pewdiepie-archdaemon/odysseus.git#main
ODYSSEUS_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
ODYSSEUS_CHAT_UPLOAD_MAX_BYTES=52428800

# LiteLLM router consumed by Odysseus as an OpenAI-compatible provider.
LLM_ROUTER_BIND=127.0.0.1
LLM_ROUTER_PORT=4000
YIELDSWARM_ROUTER_API_KEY=replace_with_long_random_router_key
YIELDSWARM_EMBEDDING_MODEL=akash-ollama-embed

# Provider backends behind the router.
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
FIREWORKS_API_KEY=your_fireworks_key_here
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
AKASH_OLLAMA_BASE_URL=http://akash-ollama-worker.internal:11434
AKASH_OLLAMA_HOSTS=akash-ollama-worker.internal:11434
AKASH_OLLAMA_MODEL=llama3.1:8b
AKASH_OLLAMA_EMBED_MODEL=nomic-embed-text
LOCAL_OLLAMA_BASE_URL=http://host.docker.internal:11434
LOCAL_OLLAMA_MODEL=llama3.1:8b

# Akash image tags used after scripts/build-odysseus-images.sh.
ODYSSEUS_IMAGE=ghcr.io/yieldswarm/odysseus:main
YIELDSWARM_LITELLM_IMAGE=ghcr.io/yieldswarm/litellm-router:main
YIELDSWARM_DEITY_COUNT=169

# Blockchain & RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_key_here
BIRDEYE_API_KEY=your_birdeye_key_here
JUPITER_API_KEY=your_jupiter_key_here
RAYDIUM_API_KEY=your_raydium_key_here
PUMP_FUN_DEPLOY_KEY=your_pump_fun_key_here
TON_API_KEY=your_ton_key_here
TAO_SUBNET_KEY=your_tao_key_here
HELIX_CHAIN_BRIDGE_KEY=your_helix_bridge_key_here
ZEC_SHIELDED_KEY=your_zec_key_here
ERC4337_BUNDLER_KEY=your_erc4337_key_here

# $APN Specifics (Apollo Nexus Engine)
APN_MINT_ADDRESS=8JC3My2QqsK4fyTC8Ki3SJ6YZQ4miavzmAt82K1Kpump
PUMP_FUN_COIN_ID=8JC3My2QqsK4fyTC8Ki3SJ6YZQ4miavzmAt82K1Kpump
RAYDIUM_POOL_ID=your_raydium_pool_id_here
LP_TOKEN_ADDRESS=your_lp_token_address_here
SLIPPAGE_TOLERANCE=0.005
MAX_FEE_PERCENT=0.01
IMPERMANENT_LOSS_THRESHOLD=0.1
MAYHEM_MODE_ENABLED=true

# ========================================
# IMPORTANT - Operations, DePIN, Yield & Cron
# ========================================
AGENT_COUNT_TOTAL=10080
AGENTS_PER_SHARD=84
AGENT_SHARD_ID=0  # Override per cron/shard (0-119)
CRON_SHARD_COUNT=120
CRON_INTERVAL_MINUTES=15

# Odysseus ChromaDB Long-Term Memory
ODYSSEUS_CHROMA_MODE=http  # http, persistent, or jsonl fallback
ODYSSEUS_CHROMA_HOST=chromadb.internal
ODYSSEUS_CHROMA_PORT=8000
ODYSSEUS_CHROMA_SSL=false
ODYSSEUS_CHROMA_TOKEN=your_chromadb_token_here
ODYSSEUS_CHROMA_TENANT=default_tenant
ODYSSEUS_CHROMA_DATABASE=default_database
ODYSSEUS_CHROMA_PERSIST_DIR=.odysseus/chroma
ODYSSEUS_CHROMA_COLLECTION_PREFIX=yieldswarm_odysseus
ODYSSEUS_NODE_ID=akash-worker-000
ODYSSEUS_SYNC_HOST=0.0.0.0
ODYSSEUS_SYNC_PORT=8097
ODYSSEUS_SYNC_TOKEN=your_odysseus_sync_token_here
ODYSSEUS_SYNC_PEERS='["https://worker-001.example.com", "https://worker-002.example.com"]'
ODYSSEUS_SYNC_OUTBOX_PATH=.odysseus/memory-outbox.jsonl
ODYSSEUS_SYNC_CURSOR_DIR=.odysseus/sync-cursors

# DePIN & Hardware
DEPIN_HELIUM_HOTSPOT_KEYS='["hotspot1_key", "hotspot2_key"]'  # JSON array
GPU_CLUSTER_KEYS='["runpod_key1", "rtx4090_key"]'
YIELDSWARM_RTX3090_WORKER_COUNT=3
YIELDSWARM_AKASH_WORKERS='[{"worker_id":"akash-rtx3090-1","provider_uri":"http://akash-rtx3090-1.local:8000","gpu_model":"RTX 3090","total_vram_gb":24,"reserved_vram_gb":2,"queue_depth":0,"health_score":1.0},{"worker_id":"akash-rtx3090-2","provider_uri":"http://akash-rtx3090-2.local:8000","gpu_model":"RTX 3090","total_vram_gb":24,"reserved_vram_gb":2,"queue_depth":0,"health_score":1.0}]'
YIELDSWARM_MODEL_CATALOG='[{"model_id":"llama-3.1-8b-instruct-q5","display_name":"Llama 3.1 8B Instruct Q5","tasks":["chat","coding","agent","general"],"vram_required_gb":8,"base_quality":0.82,"tokens_per_second":52,"emission_weight":0.88,"mutation_affinity":0.64},{"model_id":"qwen2.5-coder-7b-q5","display_name":"Qwen2.5 Coder 7B Q5","tasks":["coding","tool","agent"],"vram_required_gb":8.5,"base_quality":0.84,"tokens_per_second":48,"emission_weight":0.9,"mutation_affinity":0.72},{"model_id":"mixtral-8x7b-instruct-q4","display_name":"Mixtral 8x7B Instruct Q4","tasks":["chat","reasoning","agent"],"vram_required_gb":20.5,"base_quality":0.9,"tokens_per_second":18,"emission_weight":0.98,"mutation_affinity":0.82,"min_free_vram_after_load_gb":0.8}]'
YIELDSWARM_ROUTER_HOST=0.0.0.0
YIELDSWARM_ROUTER_PORT=8088
YIELDSWARM_API_ACCESS_LOG=false
GRASS_NODE_KEYS='["grass_node1"]'
SMARTTHINGS_BRIDGE_TOKEN=your_smartthings_token_here
COLORADO_POWER_PERMIT_ID=your_permit_id_here
UTILITY_API_KEY=your_utility_key_here

# Odysseus GPU Service
ODYSSEUS_ENABLED=true
ODYSSEUS_IMAGE=ghcr.io/yieldswarm/agent-swarm-odysseus:latest
ODYSSEUS_SERVICE_NAME=odysseus
ODYSSEUS_AGENT_COUNT=84
ODYSSEUS_GPU_COUNT=1
ODYSSEUS_GPU_CLASS=nvidia-h100
ODYSSEUS_PORT=8080
ODYSSEUS_BRAIN_URL=http://127.0.0.1:8090
# Store these in Vault at ODYSSEUS_RUNTIME_VAULT_PATH, not in .env:
# - ODYSSEUS_API_KEY
# - ODYSSEUS_MODEL_HOST
# - ODYSSEUS_MODEL_API_KEY
# Store deployment-only settings in Vault at ODYSSEUS_DEPLOY_VAULT_PATH:
# - image_repository
# - AKASH_KEY_NAME
# - AKASH_CHAIN_ID
# - AKASH_NODE
# - AKASH_FEES

# Integrations
NOTION_API_KEY=your_notion_key_here
LINEAR_API_KEY=your_linear_key_here
VERCEL_API_TOKEN=your_vercel_token_here
GITHUB_TOKEN=your_github_token_here
S_AND_P_API_KEY=your_sp_key_here
FSD_DATA_FEED_KEY=your_fsd_key_here
TESLA_INTEGRATION_TOKEN=your_tesla_token_here

# Arena + Portal + Odysseus frontend integration
AKASH_TELEMETRY_URL=/api/telemetry/akash
ODYSSEUS_TELEMETRY_URL=/api/telemetry/odysseus
ODYSSEUS_WORKSPACE_URL=/odysseus
YIELDSWARM_AUTH_SESSION_URL=/api/auth/session
YIELDSWARM_AUTH_HANDOFF_URL=/api/auth/odysseus/handoff
YIELDSWARM_AUTH_COOKIE_DOMAIN=.yieldswarm.local
YIELDSWARM_AUTH_AUDIENCE=odysseus
YIELDSWARM_TELEMETRY_REFRESH_MS=30000

# Trading & Yield
RATE_LIMIT_RPM=60
TOKEN_BUDGET_DAILY=1000000
REFERRAL_BONUS_RATE=0.05
AGENT_REFERRAL_TARGET=10000

# ========================================
# OPTIONAL - Monitoring, Social, Marketing & Scaling
# ========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
X_API_KEYS='["x_key1", "x_key2"]'
META_ADS_TOKEN=your_meta_ads_token_here
AD_CAMPAIGN_BUDGET=20
IPFS_GATEWAY=https://ipfs.io
FILECOIN_STORAGE_KEY=your_filecoin_key_here
MONITORING_PROMETHEUS_URL=your_prometheus_url_here
YIELDSWARM_AKASH_API_URL=your_akash_lease_adapter_url_here
YIELDSWARM_EMISSION_ROUTER_URL=your_emission_router_adapter_url_here
YIELDSWARM_EMISSION_ROUTER_ADDRESS=your_default_emission_router_address_here
YIELDSWARM_UNIFIED_WALLET_SDK_MODULE=your_unified_wallet_sdk_python_module_here
YIELDSWARM_UNIFIED_WALLET_API_URL=your_unified_wallet_api_url_here
YIELDSWARM_TELEMETRY_URL=your_akash_worker_telemetry_url_here
LOG_LEVEL=INFO
ERROR_WEBHOOK=your_error_webhook_here
NETWORK_LOCKDOWN_MODE=true
ADMIN_ACCOUNT_SEGMENT=your_admin_segment_here
QUARANTINED_LLM_ARENA_KEY=your_arena_key_here
ZKML_VERIFIER_KEY=your_zkml_key_here
DEXSCREENER_API=your_dexscreener_key_here
SOLSCAN_API_KEY=your_solscan_key_here
EMAIL_SMTP_CONFIG='{"host": "smtp.gmail.com", "port": 587}'
BACKUP_CRON_INTERVAL=1440
FAILOVER_RPC_LIST='["rpc1", "rpc2"]'

# Immune Bug Bounty & Bittensor
BUG_BOUNTY_AGENT_ENABLED=true
NG64_BITTENSOR_NODE_STAKING_KEY=your_ng64_staking_key_here
BITTENSOR_TRAINING_CONFIG='{"model": "your_model", "epochs": 10}'

# Unstoppable Domains & Payments
UD_API_KEY=your_ud_api_key_here
WISE_BUSINESS_EMAIL=cbrown03777@gmail.com

# ========================================
# PAYMENT RAILS APP (Next.js) — Square + Wise + Web3 + Stripe on/off ramps
# See README "Payments App" section for the full flow.
# ========================================

# --- App / session ---
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=change_me_to_a_long_random_string
# Persistence driver for the demo store: "memory" (default) or "file".
# Swap the Store implementation for Neon/Postgres in production (see src/lib/db/store.ts).
PAYMENTS_STORE_DRIVER=memory
PAYMENTS_STORE_DIR=.data

# --- Stripe (1% customer fee — see src/lib/payments/fees.ts) ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
NEXT_PUBLIC_PLATFORM_FEE_RATE=0.01

# --- Square (fiat deposits: card + ACH) ---
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=sandbox            # sandbox | production
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
SQUARE_WEBHOOK_URL=http://localhost:3000/api/webhooks/square
# Public (browser) Web Payments SDK config — enables the embedded card+ACH form.
NEXT_PUBLIC_SQUARE_APP_ID=your_square_application_id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox

# --- Wise (fiat payouts/transfers + inbound) ---
WISE_API_TOKEN=your_wise_api_token
WISE_PROFILE_ID=your_wise_profile_id
WISE_SANDBOX=true                     # true -> api.sandbox.transferwise.tech
# WISE_API_BASE=https://api.transferwise.com   # optional explicit override
# RSA public key Wise uses to sign webhook deliveries (PEM; \n allowed).
WISE_WEBHOOK_PUBLIC_KEY=

# --- Web3 RPC endpoints (use paid/dedicated RPCs in production) ---
EVM_RPC_URL_1=https://eth.llamarpc.com
EVM_RPC_URL_8453=https://mainnet.base.org
EVM_RPC_URL_137=https://polygon-rpc.com
EVM_RPC_URL_42161=https://arb1.arbitrum.io/rpc
# SOLANA_RPC_URL is reused from the Blockchain section above.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
TON_API_BASE=https://tonapi.io
# TON_API_KEY reused from the Blockchain section above.

# --- Treasury deposit addresses (where on-chain deposits are sent) ---
TREASURY_EVM_ADDRESS=
TREASURY_SOLANA_ADDRESS=
TREASURY_TON_ADDRESS=

# --- Hot wallets (off-ramp: withdrawals to user wallets) ---
HOT_WALLET_EVM_PRIVATE_KEY=
# Solana secret key as a JSON byte array ("[12,34,...]") or base64.
HOT_WALLET_SOLANA_SECRET_KEY=
ONCHAIN_MIN_CONFIRMATIONS=3

# Great Delta Emission Router — 50/30/15/5 treasury split (basis points)
SPLIT_CORE_BPS=5000
SPLIT_GROWTH_BPS=3000
SPLIT_INSURANCE_BPS=1500
SPLIT_OPS_BPS=500
EMISSION_ROUTER_ADDRESS=
TREASURY_ADDRESS=

# --- TON Connect (frontend) ---
NEXT_PUBLIC_TONCONNECT_MANIFEST_URL=http://localhost:3000/tonconnect-manifest.json

# ========================================
# Kairo — Driver App + DePIN Telemetry
# ========================================
KAIRO_API_PORT=8100
KAIRO_API_URL=http://127.0.0.1:8100
KAIRO_IDENTITY_STORE=.data/kairo/identities
KAIRO_MANDELBROT_STORE=.data/kairo/mandelbrot
KAIRO_DEPIN_REWARD_RATE=0.02
KAIRO_CORS_ORIGINS=http://localhost:5174,http://localhost:3000
VITE_KAIRO_API_URL=http://127.0.0.1:8100
VITE_MAPBOX_TOKEN=your_mapbox_token_here
ODYSSEUS_CHROMA_URL=

# Vercel Deployments (Reference)
VERCEL_DEPLOYMENT_1=https://v2-0-bay.vercel.app/
VERCEL_PROJECT=https://vercel.com/support-6930s-projects/v2-0/c64SWNEkWaF39C4GcjFPYoLxWgMg

# Additional Sharded/Per-Cron Overrides (Example)
# CRON_SCHEDULE_001=0 */15 * * *
# ... up to CRON_SCHEDULE_120

# ========================================
# Deployment Notes
# - Vercel/Azure/Render: inject Vault coordinates only; keep API keys in Vault
# - Odysseus: deploy with scripts/deploy-production-odysseus.sh or Akash SDL
# - Security: load secrets from HashiCorp Vault, never log values
# - Test: Start with 1 shard (84 agents) before full 10k