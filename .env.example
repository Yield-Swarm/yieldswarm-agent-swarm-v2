HELIUS_API_KEY=replace_me
BIRDEYE_API_KEY=replace_me
JUPITER_API_KEY=replace_me
RAYDIUM_API_KEY=replace_me
PUMP_FUN_DEPLOY_KEY=replace_me
TON_API_KEY=replace_me
