# YieldSwarm AgentSwarm OS — Environment Variable Reference
#
# PRODUCTION: Do NOT use a .env file. All secrets live in HashiCorp Vault.
# See SECRETS.md for the complete setup guide.
#
# LOCAL DEV ONLY: Copy to .env and point agents at a dev Vault instance.

# ========================================
# Vault connection (required for all deployments)
# ========================================
VAULT_ADDR=https://vault.yieldswarm.internal:8200
VAULT_ROLE_ID=your_approle_role_id_here
VAULT_SECRET_ID=your_single_use_secret_id_here

# ========================================
# Non-secret configuration (safe in .env)
# ========================================
AGENT_COUNT_TOTAL=10080
AGENTS_PER_SHARD=84
AGENT_SHARD_ID=0
CRON_SHARD_COUNT=120
CRON_INTERVAL_MINUTES=15
LOG_LEVEL=INFO
ENVIRONMENT=production

# Agent module to run (Python module path)
AGENT_MODULE=agents.akash_optimizer

# Akash network (non-secret)
AKASH_CHAIN_ID=akashnet-2
AKASH_NODE=https://rpc.akash.forbole.com:443

# ========================================
# Secrets below are stored in Vault at runtime.
# Listed here for reference only — DO NOT fill in real values.
# ========================================
# AGENTSWARM_MASTER_KEY      → secret/yieldswarm/agents/shared
# SOLANA_RPC_URL              → secret/yieldswarm/rpc/solana
# HELIUS_API_KEY              → secret/yieldswarm/rpc/solana
# FAILOVER_RPC_LIST           → secret/yieldswarm/rpc/failover
# RUNPOD_API_KEY              → secret/yieldswarm/runpod/api
# VULTR_API_KEY               → secret/yieldswarm/vultr/api
# DO_API_TOKEN                → secret/yieldswarm/digitalocean/api
# AZURE_CLIENT_ID/SECRET      → secret/yieldswarm/azure/credentials
# AKASH_WALLET_MNEMONIC       → secret/yieldswarm/akash/runtime

# ========================================
# Deployment targets
# ========================================
# Vercel: Use Vault Agent sidecar or inject VAULT_* via dashboard
# Azure:  Container App secrets reference AppRole creds (see terraform/azure.tf)
# Akash:  deploy.sh injects single-use secret-id at deploy time
# Security: Inject via Vault AppRole, never log values
