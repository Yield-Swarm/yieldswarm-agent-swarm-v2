# ==============================================================================
# SECURE REFACTORED TEMPLATE — DO NOT ENTER PLAINTEXT SECRETS HERE
# ==============================================================================
# Copy:  cp .env.template .env
# Inject secrets:  ./scripts/inject_secrets.sh
# Phase 1 docs:    docs/PHASE1_SECURE_ENV.md
# Phase 2 bridge:  docs/cursor-prompts/PHASE2_HELIX_CHAIN_BRIDGE.md
# Vault (legacy):  docs/VAULT_ENV_INJECTION.md
# ==============================================================================

NODE_ENV="production"
NETWORK_LOCKDOWN_MODE=true
PRIMARY_DOMAIN="yoeldswarm.polsia.app"
TARGET_ENV=mainnet
API_BASE=https://api.yoeldswarm.polsia.app

# ------------------------------------------------------------------------------
# TEE Guardian & Azure Identity (DefaultAzureCredential at runtime)
# ------------------------------------------------------------------------------
AZURE_KEYVAULT_NAME="[your-keyvault-name]"
AZURE_TENANT_ID="[your-tenant-id]"
AZURE_SUBSCRIPTION_ID="[your-subscription-id]"
TEE_ENCLAVE_PROVIDER="AZURE_SGX_TDX"

# ------------------------------------------------------------------------------
# Swarm Security Orchestration Keys (inject via Key Vault / enclave only)
# ------------------------------------------------------------------------------
AGENTSWARM_MASTER_KEY="KV_SECRET_REF:agentswarm-master-key"
KIMICLAW_CONSENSUS_KEY="KV_SECRET_REF:kimiclaw-consensus-key"
GROK_API_KEY="KV_SECRET_REF:grok-api-key"
OPENAI_API_KEY="KV_SECRET_REF:openai-api-key"
GEMINI_API_KEY="KV_SECRET_REF:gemini-api-key"
OPENROUTER_API_KEY="KV_SECRET_REF:openrouter-api-key"
TEE_SIGNING_KEY="KV_SECRET_REF:tee-signing-key"
DATABASE_ENCRYPTION_KEY="KV_SECRET_REF:database-encryption-key"
HELIX_CHAIN_BRIDGE_KEY="KV_SECRET_REF:helix-chain-bridge-key"

# ------------------------------------------------------------------------------
# External Webhooks & Infrastructure Providers
# ------------------------------------------------------------------------------
PINATA_API_KEY="KV_SECRET_REF:pinata-api-key"
PINATA_SECRET="KV_SECRET_REF:pinata-secret"
PINATA_JWT="KV_SECRET_REF:pinata-jwt"
RESEND_API_KEY="KV_SECRET_REF:resend-api-key"
CLOUDFLARE_ACCESS_CLIENT_ID="KV_SECRET_REF:cf-access-client-id"
CLOUDFLARE_ACCESS_CLIENT_SECRET="KV_SECRET_REF:cf-access-client-secret"
CLOUDFLARE_API_TOKEN="KV_SECRET_REF:cloudflare-api-token"
SENTRY_DSN="KV_SECRET_REF:sentry-dsn"
NOTION_API_KEY="KV_SECRET_REF:notion-api-key"
TELEGRAM_BOT_TOKEN="KV_SECRET_REF:telegram-bot-token"

# ------------------------------------------------------------------------------
# Helix & Cross-Chain RPC Architecture
# ------------------------------------------------------------------------------
HELIX_CHAIN_ENDPOINT="https://rpc.helix.polsia.app"
HELIX_CHAIN_ENABLED=0
QUICKNODE_SOLANA_RPC_URL="KV_SECRET_REF:qn-solana-rpc"
QUICKNODE_API_KEY="KV_SECRET_REF:quicknode-api-key"
SOLANA_RPC_URL="KV_SECRET_REF:solana-rpc-url"
HELIUS_API_KEY="KV_SECRET_REF:helius-api-key"
JUPITER_API_KEY="KV_SECRET_REF:jupiter-api-key"
INFURA_PROJECT_ID="KV_SECRET_REF:infura-project-id"
INFURA_API_KEY="KV_SECRET_REF:infura-api-key"
INFURA_SOL_MAINNET_RPC="KV_SECRET_REF:infura-sol-mainnet-rpc"
ANKR_API_KEY="KV_SECRET_REF:ankr-api-key"
ANKR_RPC_MULTICHAIN="KV_SECRET_REF:ankr-rpc-multichain"
ETHEREUM_RPC_URL="https://eth.llamarpc.com"
TENDERLY_API_KEY="KV_SECRET_REF:tenderly-api-key"
TENDERLY_ACCOUNT="[your-tenderly-account-slug]"
TENDERLY_PROJECT="KV_SECRET_REF:tenderly-project"
TENDERLY_PROJECT_URL="KV_SECRET_REF:tenderly-project-url"

# ------------------------------------------------------------------------------
# $APN / Trading Guardrails (non-secret defaults)
# ------------------------------------------------------------------------------
APN_MINT_ADDRESS="KV_SECRET_REF:apn-mint-address"
PUMP_FUN_COIN_ID="KV_SECRET_REF:pump-fun-coin-id"
SLIPPAGE_TOLERANCE=0.005
MAX_FEE_PERCENT=0.01
IMPERMANENT_LOSS_THRESHOLD=0.1
MAYHEM_MODE_ENABLED=true
CROSS_CHAIN_MVP_ENABLED=true
CROSS_CHAIN_DRY_RUN=1

# ------------------------------------------------------------------------------
# Sharding Metrics & Scale Layouts (non-secret)
# ------------------------------------------------------------------------------
AGENT_COUNT_TOTAL=10080
CRON_SHARD_COUNT=120
AGENTS_PER_SHARD=84
CRON_INTERVAL_MINUTES=15

# ------------------------------------------------------------------------------
# HashiCorp Vault (optional parallel secret plane — see docs/VAULT_ENV_INJECTION.md)
# ------------------------------------------------------------------------------
VAULT_ADDR="https://vault.example.com"
VAULT_KV_MOUNT=yieldswarm
VAULT_AUTH_METHOD=approle
USE_VAULT_AKASH=false

# ------------------------------------------------------------------------------
# Monitoring (DSN is secret; rates are config)
# ------------------------------------------------------------------------------
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Greek Layer (non-secret — passed in SDL / container env)
# ------------------------------------------------------------------------------
GREEK_LAYER__ACCESS_CONTROL_ENABLED=true
GREEK_LAYER__MAX_CONTEXT_WINDOW=32
GREEK_LAYER__STRICT_SANITIZATION=true
EASTERN_LAYER__FEEDBACK_ENABLED=true
EASTERN_LAYER__RECURSIVE_ROUTING=true
