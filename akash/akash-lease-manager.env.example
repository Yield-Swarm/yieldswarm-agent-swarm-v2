# ===========================================================================
# Akash Lease Manager configuration
# Copy to .env (in this directory or the repo root) and fill in real values.
# Both akash-deploy.sh and lease-manager.py read these variables.
# ===========================================================================

# --- Akash CLI / chain ------------------------------------------------------
# Path or name of the Akash CLI binary (provider-services on modern installs).
AKASH_BIN=provider-services
AKASH_NODE=https://rpc.akashnet.net:443
AKASH_CHAIN_ID=akashnet-2
AKASH_KEYRING_BACKEND=os
# Key name in the Akash keyring used to sign deployment/lease transactions.
AKASH_KEY_NAME=default
# Owner address (auto-derived from AKASH_KEY_NAME if left blank).
AKASH_ACCOUNT_ADDRESS=
AKASH_GAS=auto
AKASH_GAS_ADJUSTMENT=1.4
AKASH_GAS_PRICES=0.025uakt
# Set AKASH_FEES to use a flat fee instead of gas prices (optional).
AKASH_FEES=

# --- GPU targeting / deployment --------------------------------------------
AKASH_GPU_MODEL=rtx3090
AKASH_SDL_FILE=./worker.sdl.yml
# Max acceptable bid price (uakt per block). Bids above this are skipped.
AKASH_MAX_BID_PRICE=100000
# How long to wait for provider bids before giving up (seconds).
AKASH_BID_WAIT_SECONDS=45
AKASH_BID_POLL_INTERVAL=5
# Only lease from audited providers when true.
AKASH_REQUIRE_AUDITED=false
# Retries for chain queries / txs.
AKASH_TX_RETRIES=3

# --- Lease manager behaviour -----------------------------------------------
# Health-check cadence in seconds (the spec calls for 60).
HEALTH_CHECK_INTERVAL=60
# HTTP path appended to each worker URL for health probing.
HEALTH_PATH=/healthz
HEALTH_TIMEOUT=10
HEALTH_RETRIES=3
HEALTH_RETRY_DELAY=5
# Consecutive failed cycles before a worker is declared dead and replaced.
FAILURE_THRESHOLD=2
# Desired number of healthy workers; the manager scales up to this count.
DESIRED_WORKERS=1
# Close the old (dead) lease after a successful replacement to stop billing.
CLOSE_DEAD_LEASES=true
# Max seconds to allow a single akash-deploy.sh deploy to run.
DEPLOY_TIMEOUT=600
# Simulate everything without touching Akash (great for testing).
DRY_RUN=false

# --- Paths ------------------------------------------------------------------
AKASH_DEPLOY_SCRIPT=./akash-deploy.sh
LEASE_STATE_FILE=./state/workers.json
LEASE_MANAGER_PIDFILE=./state/lease-manager.pid
LEASE_MANAGER_LOG=./state/lease-manager.log

# --- Frontend telemetry -----------------------------------------------------
TELEMETRY_JSON=./telemetry/telemetry.json
TELEMETRY_HTML=./telemetry/index.html
# Optional: POST the telemetry payload to a frontend/ingest endpoint as well.
TELEMETRY_WEBHOOK=
