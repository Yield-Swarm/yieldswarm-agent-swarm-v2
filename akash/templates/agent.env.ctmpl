{{/*
  agent.env.ctmpl
  Rendered by Vault Agent into /run/secrets/agent.env.
  The Akash workload sources this file before exec'ing the python agent.
  Re-rendered automatically on KV version bump.
*/ -}}

# --- Akash runtime bundle ------------------------------------------------
{{- with secret "yieldswarm/data/akash/runtime" }}
AGENTSWARM_MASTER_KEY={{ .Data.data.master_key }}
KIMICLAW_CONSENSUS_KEY={{ .Data.data.kimiclaw_key }}
WALLET_ENCRYPTION_KEY={{ .Data.data.wallet_encryption_key }}
TEE_SIGNING_KEY={{ .Data.data.tee_signing_key }}
DATABASE_ENCRYPTION_KEY={{ .Data.data.database_encryption_key }}
{{- end }}

# --- Per-shard secrets (driven by AGENT_SHARD_ID env-var from SDL) -----
{{- with secret (printf "yieldswarm/data/agents/shards/%s" (env "AGENT_SHARD_ID")) }}
AGENT_SHARD_ID={{ env "AGENT_SHARD_ID" }}
AGENT_API_KEY={{ .Data.data.api_key }}
AGENT_SIGNING_KEY={{ .Data.data.signing_key }}
{{- end }}

# --- RPC providers -------------------------------------------------------
{{- with secret "yieldswarm/data/rpc/helius" }}
HELIUS_API_KEY={{ .Data.data.api_key }}
{{- end }}
{{- with secret "yieldswarm/data/rpc/birdeye" }}
BIRDEYE_API_KEY={{ .Data.data.api_key }}
{{- end }}
{{- with secret "yieldswarm/data/rpc/jupiter" }}
JUPITER_API_KEY={{ .Data.data.api_key }}
{{- end }}
{{- with secret "yieldswarm/data/rpc/raydium" }}
RAYDIUM_API_KEY={{ .Data.data.api_key }}
{{- end }}
{{- with secret "yieldswarm/data/rpc/ton" }}
TON_API_KEY={{ .Data.data.api_key }}
{{- end }}
{{- with secret "yieldswarm/data/rpc/solana" }}
SOLANA_RPC_URL={{ .Data.data.http_url }}
SOLANA_WS_URL={{ .Data.data.ws_url }}
{{- end }}

# --- LLM providers -------------------------------------------------------
{{- with secret "yieldswarm/data/llm/openai" }}
OPENAI_API_KEY={{ .Data.data.api_key }}
{{- end }}
{{- with secret "yieldswarm/data/llm/anthropic" }}
ANTHROPIC_API_KEY={{ .Data.data.api_key }}
{{- end }}
{{- with secret "yieldswarm/data/llm/grok" }}
GROK_API_KEY={{ .Data.data.api_key }}
{{- end }}
{{- with secret "yieldswarm/data/llm/gemini" }}
GEMINI_API_KEY={{ .Data.data.api_key }}
{{- end }}
