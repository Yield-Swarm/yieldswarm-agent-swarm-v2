{{/*
  runtime.env.ctmpl — canonical Vault Agent template for Akash workloads.

  Rendered to AGENT_ENV_FILE (default /run/secrets/agent.env). Paths MUST
  match vault/policies/akash-runtime.hcl. Legacy akash/* paths are included
  as fallbacks for older seed layouts.
*/ -}}

# --- Legacy akash/runtime bundle (fallback — canonical sections below win) ---
{{- with secret "yieldswarm/data/akash/runtime" -}}
AGENTSWARM_MASTER_KEY={{ .Data.data.master_key | toJSON }}
KIMICLAW_CONSENSUS_KEY={{ .Data.data.kimiclaw_key | toJSON }}
WALLET_ENCRYPTION_KEY={{ .Data.data.wallet_encryption_key | toJSON }}
TEE_SIGNING_KEY={{ .Data.data.tee_signing_key | toJSON }}
DATABASE_ENCRYPTION_KEY={{ .Data.data.database_encryption_key | toJSON }}
{{- end }}

# --- Runtime core (canonical) --------------------------------------------
{{- with secret "yieldswarm/data/runtime/core" -}}
AGENTSWARM_MASTER_KEY={{ .Data.data.agentswarm_master_key | toJSON }}
KIMICLAW_CONSENSUS_KEY={{ .Data.data.kimiclaw_consensus_key | toJSON }}
DATABASE_ENCRYPTION_KEY={{ .Data.data.database_encryption_key | toJSON }}
{{- end }}

# --- Wallets (canonical) ---------------------------------------------------
{{- with secret "yieldswarm/data/runtime/wallets" -}}
WALLET_ENCRYPTION_KEY={{ .Data.data.wallet_encryption_key | toJSON }}
TEE_SIGNING_KEY={{ .Data.data.tee_signing_key | toJSON }}
PUMP_FUN_DEPLOY_KEY={{ .Data.data.pump_fun_deploy_key | toJSON }}
ERC4337_BUNDLER_KEY={{ .Data.data.erc4337_bundler_key | toJSON }}
HELIX_CHAIN_BRIDGE_KEY={{ .Data.data.helix_chain_bridge_key | toJSON }}
ZEC_SHIELDED_KEY={{ .Data.data.zec_shielded_key | toJSON }}
{{- end }}

# --- Per-shard secrets (AGENT_SHARD_ID from SDL) --------------------------
{{- with secret (printf "yieldswarm/data/agents/shards/%s" (env "AGENT_SHARD_ID")) -}}
AGENT_SHARD_ID={{ env "AGENT_SHARD_ID" | toJSON }}
AGENT_API_KEY={{ .Data.data.api_key | toJSON }}
AGENT_SIGNING_KEY={{ .Data.data.signing_key | toJSON }}
{{- end }}

# --- LLM providers (legacy fallbacks, then canonical) --------------------
{{- with secret "yieldswarm/data/llm/openai" }}OPENAI_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/llm/anthropic" }}ANTHROPIC_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/llm/grok" }}GROK_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/llm/gemini" }}GEMINI_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/runtime/llm" -}}
OPENAI_API_KEY={{ .Data.data.openai_api_key | toJSON }}
ANTHROPIC_API_KEY={{ .Data.data.anthropic_api_key | toJSON }}
GROK_API_KEY={{ .Data.data.grok_api_key | toJSON }}
GEMINI_API_KEY={{ .Data.data.gemini_api_key | toJSON }}
OPENROUTER_API_KEY={{ .Data.data.openrouter_api_key | toJSON }}
FIREWORKS_API_KEY={{ .Data.data.fireworks_api_key | toJSON }}
{{- end }}

# --- RPC providers (legacy fallbacks, then canonical) --------------------
{{- with secret "yieldswarm/data/rpc/helius" }}HELIUS_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/rpc/birdeye" }}BIRDEYE_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/rpc/jupiter" }}JUPITER_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/rpc/raydium" }}RAYDIUM_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/rpc/ton" }}TON_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/rpc/solana" -}}
SOLANA_RPC_URL={{ .Data.data.url | default .Data.data.http_url | toJSON }}
SOLANA_WS_URL={{ .Data.data.ws_url | toJSON }}
HELIUS_API_KEY={{ .Data.data.helius_api_key | toJSON }}
BIRDEYE_API_KEY={{ .Data.data.birdeye_api_key | toJSON }}
JUPITER_API_KEY={{ .Data.data.jupiter_api_key | toJSON }}
{{- end }}
{{- with secret "yieldswarm/data/rpc/ethereum" -}}
ETHEREUM_RPC_URL={{ .Data.data.url | toJSON }}
ALCHEMY_API_KEY={{ .Data.data.alchemy_api_key | toJSON }}
INFURA_PROJECT_ID={{ .Data.data.infura_project_id | toJSON }}
{{- end }}
{{- with secret "yieldswarm/data/rpc/bittensor" -}}
NG64_BITTENSOR_NODE_STAKING_KEY={{ .Data.data.staking_key | toJSON }}
{{- end }}

# --- Integrations --------------------------------------------------------
{{- with secret "yieldswarm/data/integrations/github" }}GITHUB_TOKEN={{ .Data.data.token | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/integrations/vercel" }}VERCEL_API_TOKEN={{ .Data.data.token | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/integrations/notion" }}NOTION_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/integrations/linear" }}LINEAR_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/integrations/telegram" }}TELEGRAM_BOT_TOKEN={{ .Data.data.bot_token | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/integrations/unstoppable" }}UD_API_KEY={{ .Data.data.api_key | toJSON }}{{ end }}
{{- with secret "yieldswarm/data/integrations/alchemy" -}}
ALCHEMY_API_KEY={{ .Data.data.api_key | toJSON }}
ALCHEMY_APP_NAME={{ .Data.data.app_name | toJSON }}
{{- end }}

# --- Optional workload profiles (ignored if path missing / denied) -------
{{- with secret "yieldswarm/data/runtime/kairo" -}}
MAPBOX_TOKEN={{ .Data.data.mapbox_token | toJSON }}
IOTEX_API_KEY={{ .Data.data.iotex_api_key | toJSON }}
KAIRO_IDENTITY_SIGNING_KEY={{ .Data.data.identity_signing_key | toJSON }}
{{- end }}
{{- with secret "yieldswarm/data/runtime/payments" -}}
STRIPE_SECRET_KEY={{ .Data.data.stripe_secret_key | toJSON }}
STRIPE_WEBHOOK_SECRET={{ .Data.data.stripe_webhook_secret | toJSON }}
STRIPE_PUBLISHABLE_KEY={{ .Data.data.stripe_publishable_key | toJSON }}
{{- end }}
{{- with secret "yieldswarm/data/runtime/odysseus" -}}
ODYSSEUS_API_KEY={{ .Data.data.api_key | toJSON }}
ODYSSEUS_MODEL_HOST={{ .Data.data.model_host | toJSON }}
ODYSSEUS_MODEL_API_KEY={{ .Data.data.model_api_key | toJSON }}
{{- end }}
{{- with secret "yieldswarm/data/runtime/bittensor" -}}
BT_WALLET_NAME={{ .Data.data.wallet_name | toJSON }}
BT_HOTKEY_NAME={{ .Data.data.hotkey_name | toJSON }}
BITTENSOR_WALLET_JSON={{ .Data.data.wallet_json | toJSON }}
BT_NETUID={{ .Data.data.netuid | toJSON }}
BT_NETWORK={{ .Data.data.network | toJSON }}
OLLAMA_MODEL={{ .Data.data.ollama_model | toJSON }}
{{- end }}
