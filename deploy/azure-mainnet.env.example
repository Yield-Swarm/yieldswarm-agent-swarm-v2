# =============================================================================
# YieldSwarm Azure Mainnet — VMSS + Load Balancer wiring parameters
# Copy to deploy/azure-mainnet.env and customize before running scripts.
# =============================================================================

# --- Azure scope ---
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=YieldSwarm
AZURE_LOCATION=centralus

# --- Public edge ---
AZURE_PUBLIC_IP=4.249.252.26
AZURE_PUBLIC_IP_NAME=Loadbalanceraitrained-publicip
AZURE_LOAD_BALANCER_NAME=Loadbalanceraitrained

# --- VMSS compute ---
AZURE_VMSS_NAME=vmss_3cf043e
AZURE_VMSS_CAPACITY=2
AZURE_VMSS_SSH_KEY_PATH=vmss_key.pem
AZURE_VMSS_SSH_USER=azureuser
AZURE_VMSS_NAT_PORT_START=50000

# --- GPU cluster VMSS (NC-series) ---
AZURE_GPU_VMSS_NAME=vmss_gpu_yieldswarm
AZURE_GPU_VMSS_CAPACITY=2
AZURE_GPU_VM_SIZE=Standard_NC4as_T4_v3
# Set DEPLOY_TERRAFORM_GPU=1 to provision via infra/terraform when GPU VMSS absent

# --- Network ---
AZURE_VNET_NAME=vnet-centralus
AZURE_NSG_NAME=basicNsgvnet-centralus-nic01
AZURE_BACKEND_SUBNET_NAME=default

# --- Application ports (VMSS instances) ---
MAINNET_APP_PORT=8080
MAINNET_TLS_PORT=8443
MAINNET_HEALTH_PATH=/api/health
MAINNET_P2P_PORT_START=50000
MAINNET_P2P_PORT_END=50003

# --- Load balancer frontend ports ---
LB_FRONTEND_HTTP_PORT=80
LB_FRONTEND_HTTPS_PORT=443
LB_PROBE_NAME=yieldswarm-mainnet-health
LB_RULE_HTTP_NAME=yieldswarm-mainnet-http
LB_RULE_HTTPS_NAME=yieldswarm-mainnet-https
LB_BACKEND_POOL_NAME=backend-pool

# --- Custom domains ---
MAINNET_DOMAIN=mainnet.yieldswarm.network
API_DOMAIN=api.yieldswarm.network
DNS_ZONE=yieldswarm.network

# --- Azure Front Door (managed TLS) ---
AFD_PROFILE_NAME=afd-yieldswarm-mainnet
AFD_ENDPOINT_NAME=yieldswarm-mainnet-edge
AFD_ORIGIN_GROUP_NAME=yieldswarm-vmss-origins
AFD_ORIGIN_NAME=yieldswarm-lb-origin
AFD_ROUTE_NAME=yieldswarm-mainnet-route
AFD_SKU=Standard_AzureFrontDoor

# --- Cross-region (optional) ---
AZURE_TRAFFIC_MANAGER_PROFILE=
AZURE_SECONDARY_REGION=eastus2

# --- Autoscale (CPU VMSS) ---
AZURE_AUTOSCALE_NAME=autoscale-vmss_3cf043e
AZURE_AUTOSCALE_MIN=2
AZURE_AUTOSCALE_MAX=10
AZURE_AUTOSCALE_DEFAULT=2
AZURE_AUTOSCALE_SCALE_OUT_CPU=75
AZURE_AUTOSCALE_SCALE_IN_CPU=30
AZURE_AUTOSCALE_CPU_DURATION=10m
AZURE_AUTOSCALE_COOLDOWN_OUT=5
AZURE_AUTOSCALE_COOLDOWN_IN=10
AZURE_AUTOSCALE_SCALE_OUT_COUNT=1
AZURE_AUTOSCALE_SCALE_IN_COUNT=1
AZURE_VMSS_SCALE_IN_POLICY=OldestVM
# Predictive: Disabled | ForecastOnly | Enabled (needs ~7d CPU history)
AZURE_AUTOSCALE_PREDICTIVE_MODE=ForecastOnly
AZURE_AUTOSCALE_LOOKAHEAD=PT15M

# --- Scheduled business-hours profile ---
AZURE_AUTOSCALE_SCHEDULE_ENABLED=1
AZURE_AUTOSCALE_SCHEDULE_NAME=business-hours
AZURE_AUTOSCALE_SCHEDULE_START=08:00
AZURE_AUTOSCALE_SCHEDULE_END=18:00
AZURE_AUTOSCALE_SCHEDULE_DAYS="mon tue wed thu fri"
AZURE_AUTOSCALE_SCHEDULE_TIMEZONE="Central Standard Time"
AZURE_AUTOSCALE_SCHEDULE_COUNT=4
AZURE_AUTOSCALE_SCHEDULE_MIN=2
AZURE_AUTOSCALE_SCHEDULE_MAX=8

# --- Autoscale (GPU VMSS) ---
AZURE_GPU_AUTOSCALE_ENABLED=1
AZURE_GPU_AUTOSCALE_NAME=autoscale-vmss_gpu_yieldswarm
AZURE_GPU_AUTOSCALE_MIN=1
AZURE_GPU_AUTOSCALE_MAX=6
AZURE_GPU_AUTOSCALE_DEFAULT=2
AZURE_GPU_AUTOSCALE_SCALE_OUT_CPU=70
AZURE_GPU_AUTOSCALE_SCALE_IN_CPU=25

# --- GPU custom metrics (Azure Monitor Agent + DCGM) ---
AZURE_CUSTOM_METRIC_NAMESPACE=YieldSwarm/GPU
DCGM_EXPORTER_PORT=9400
