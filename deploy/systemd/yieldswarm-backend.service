# YieldSwarm integration backend — dashboard API on :8080
# Install:
#   sudo cp deploy/systemd/yieldswarm-backend.service /etc/systemd/system/
#   sudo sed -i "s#__REPO__#$(pwd)#g" /etc/systemd/system/yieldswarm-backend.service
#   sudo systemctl daemon-reload && sudo systemctl enable --now yieldswarm-backend
[Unit]
Description=YieldSwarm integration backend (Arena + Command Center + Single Pane)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=__REPO__/backend
EnvironmentFile=-__REPO__/.env
Environment=PORT=8080
Environment=HOST=0.0.0.0
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
