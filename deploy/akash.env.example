# Akash deployment environment
# Copy to deploy/akash.env and fill in values (file is gitignored via deploy/config.env pattern)

# ---- Wallet (required) ----
AKASH_KEY_NAME=yieldswarm
AKASH_KEYRING_BACKEND=os
# AKASH_ACCOUNT_ADDRESS=akash1...   # auto-derived from key if unset

# ---- Chain ----
AKASH_NODE=https://rpc.akashnet.net:443
AKASH_CHAIN_ID=akashnet-2
AKASH_GAS=auto
AKASH_GAS_ADJUSTMENT=1.4
AKASH_GAS_PRICES=0.025uakt
AKASH_DEPOSIT=5000000uakt

# ---- Provider authentication ----
# jwt  = default for provider-services v0.10+ (recommended, no on-chain cert)
# mtls = legacy mTLS; requires tx cert generate + publish
AKASH_AUTH_MODE=jwt

# ---- SDL & GPU targeting ----
AKASH_SDL=deploy/deploy-swarm-monolith.yaml
AKASH_GPU_MODEL=rtx3090
AKASH_MAX_BID_PRICE=700000

# ---- Bid selection ----
AKASH_BID_WAIT_SECONDS=180
AKASH_BID_POLL_INTERVAL=10
# AKASH_PROVIDER=akash1...        # override auto-select cheapest bid

# ---- Health checks ----
HEALTH_PATH=/healthz
HEALTH_TIMEOUT_SECONDS=300
HEALTH_POLL_INTERVAL=10

# ---- State output ----
RUN_DIR=.run
STATE_FILE=.run/akash-deploy.json

# ---- Optional: load Akash secrets from Vault via JWT ----
VAULT_LOAD_AKASH=false
# VAULT_ADDR=https://vault.yieldswarm.io:8200
# VAULT_TOKEN=your_vault_token_here
# VAULT_AUTH_METHOD=jwt
# VAULT_JWT_ROLE=yieldswarm-akash-deploy
# VAULT_JWT_FILE=/var/run/secrets/kubernetes.io/serviceaccount/token
# VAULT_AKASH_SECRET_PATH=yieldswarm/data/runtime/akash

# ---- Bittensor miner (deploy/akash-bittensor-miner.sdl.yml) ----
BT_NETUID=1
BT_NETWORK=finney
BT_WALLET_NAME=miner
BT_HOTKEY_NAME=default
# DEPLOY_IMAGE=ghcr.io/yield-swarm/bittensor-miner:latest

# ---- Mining spin-up shortcuts ----
# MINING_SDL=deploy/akash-bittensor-miner.sdl.yml
# DEPLOY_SDL=deploy/deploy-swarm-monolith.yaml
# USE_VAULT_AKASH=1
# AUTO_SELECT_BID=1
