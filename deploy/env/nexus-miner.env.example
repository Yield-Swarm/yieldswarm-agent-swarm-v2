# Nexus Miner Multi-Mining — Shadow Solenoid 3 runtime sheet
# Copy to ~/.config/yieldswarm/nexus-miner.env or Render dashboard secrets.
# NEVER commit real tokens. Load from Vault where possible.

# --- Core runtime ---
SHADOW_CHAIN_ID=shadow-solenoid-3
EXECUTION_CAPACITY=0.80
NODE_ENV=production
PORT=10000

# --- Chain RPC ---
HELIX_CHAIN_RPC=https://yieldswarm-agent-swarm-v2-mainnet.onrender.com
NEXUS_CHAIN_RPC=https://w3bstream-mainnet.iotex.io/v1/projects/apollo_nexus
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC

# --- IoT / telephony ---
IOTEX_DEVICE_ID=io_nexus_pebble_01
IOTEX_W3BSTREAM_ENDPOINT=https://w3bstream-mainnet.iotex.io/v1/projects/apollo_nexus
TWILIO_ACCOUNT_SID=ACyour_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# --- AI / verification (Vault: runtime/llm or integrations/xai) ---
AZURE_AI_FOUNDRY_ENDPOINT=https://eastus.api.azureml.ms/projects/solenoid3/inference
XAI_API_KEY=your_xai_key_here
GROK_API_KEY=your_grok_key_here

# --- Singapore gateway (Neon + sync auth) ---
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
NEXUS_SYNC_API_KEY=generate_long_random_key
NEXUS_GATEWAY_URL=https://your-nexus-miner-gateway.onrender.com

# --- RunPod worker identity ---
RUNPOD_POD_INDEX=0
OPENCLAW_POD_ROOT=/opt/openclaw-pod-0
YIELDSWARM_REPO=/opt/openclaw-pod-0/yieldswarm-agent-swarm-v2
MINING_DRY_RUN=0
