# =============================================================================
# YieldSwarm — Production Launch .env (high-traffic ready)
# =============================================================================
# Copy to .env and fill placeholders. NEVER commit real secrets.
#
#   cp deploy/env/launch-production.env.example .env
#   cp deploy/akash.env.example deploy/akash.env
#
# Prefer HashiCorp Vault as source of truth:
#   ./vault/scripts/seed-secrets.sh
#   source scripts/lib/vault-env.sh && vault-export
#
# Full catalog: docs/ENV_VARS.md
# Launch commands: docs/LAUNCH_PLAYBOOK.md
# =============================================================================

TARGET_ENV=production
NODE_ENV=production
LOG_LEVEL=info

# =============================================================================
# 1. PUBLIC URLS (Vercel + UD + gateway — set before traffic spike)
# =============================================================================
APP_URL=https://yieldswarm.crypto
NEXT_PUBLIC_APP_URL=https://yieldswarm.crypto
NEXT_PUBLIC_AKASH_GATEWAY=https://gateway.yieldswarm.crypto
API_BASE=https://gateway.yieldswarm.crypto
ARENA_API_BASE=https://gateway.yieldswarm.crypto
YIELDSWARM_DEX_API_URL=https://gateway.yieldswarm.crypto
YIELDSWARM_CROSS_CHAIN_API_URL=https://gateway.yieldswarm.crypto
YIELDSWARM_TELEMETRY_URL=https://gateway.yieldswarm.crypto/api/telemetry/akash
YIELDSWARM_EMISSION_ROUTER_URL=https://gateway.yieldswarm.crypto
ODYSSEUS_WORKSPACE_URL=https://yieldswarm.crypto/odysseus
YIELDSWARM_AUTH_COOKIE_DOMAIN=.yieldswarm.crypto
SECURE_COOKIES=true

# Backend bind (Akash lease or local)
PORT=8080
HOST=0.0.0.0
HEALTHCHECK_PATH=/healthz

# =============================================================================
# 2. HASHICORP VAULT (HCP — operator bootstrap)
# =============================================================================
VAULT_ADDR=https://YOUR-CLUSTER.vault.hashicorp.cloud:8200
VAULT_NAMESPACE=admin
VAULT_AUTH_METHOD=token
# VAULT_TOKEN=hvs....          # deploy host ONLY — unset after seed/export
KV_MOUNT=yieldswarm
VAULT_INJECT_RUNTIME_SECRETS=yes
USE_VAULT_AKASH=1

# =============================================================================
# 3. SWARM ORCHESTRATION (14 book-root elevators)
# Vault: yieldswarm/runtime/swarm
# =============================================================================
SWARM_API_KEY_PRIMARY=REPLACE_FROM_VAULT_OR_CURSOR
SWARM_API_KEY_BACKEND=REPLACE_FROM_VAULT_OR_CURSOR
AGENTSWARM_MASTER_KEY=REPLACE_FROM_VAULT
YIELDSWARM_ROUTER_API_KEY=REPLACE_FROM_VAULT
NEURAL_MESH_WORKERS=14

# =============================================================================
# 4. HIGH-TRAFFIC / EDGE HARDENING
# =============================================================================
NETWORK_LOCKDOWN_MODE=true
RATE_LIMIT_RPM=300
TOKEN_BUDGET_DAILY=5000000
TELEMETRY_CACHE_TTL_MS=30000
YIELDSWARM_TELEMETRY_REFRESH_MS=60000
YIELDSWARM_API_ACCESS_LOG=false
YIELDSWARM_SYNC_AKASH_WORKERS=true
INFERENCE_ROUTER_ENABLED=true
INFERENCE_TIMEOUT_MS=120000

# Cloudflare (Vault: integrations/cloudflare + domains/runtime)
CLOUDFLARE_API_TOKEN=REPLACE_FROM_VAULT
CLOUDFLARE_ZONE_ID=REPLACE_FROM_VAULT
CLOUDFLARE_CLIENT_ID=REPLACE_FROM_VAULT
CLOUDFLARE_CLIENT_SECRET=REPLACE_FROM_VAULT

# Sentry (Vault: integrations/sentry)
SENTRY_DSN=REPLACE_FROM_VAULT
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

# Worker pool — comma-separated after Akash deploy (from .run/akash-lease.env)
# AKASH_WORKER_URLS=https://lease1.akash.pub,https://lease2.akash.pub
AKASH_TELEMETRY_URL=/api/telemetry/akash

# =============================================================================
# 5. RPC MESH — Alchemy (164 networks)
# Vault: integrations/alchemy, rpc/ethereum
# =============================================================================
ALCHEMY_API_KEY=REPLACE_FROM_VAULT
ALCHEMY_APP_NAME=Christopher's First App
ALCHEMY_REVEAL_URLS=0
CROSS_CHAIN_MVP_ENABLED=true
CROSS_CHAIN_DRY_RUN=0
FAILOVER_RPC_LIST=

# =============================================================================
# 6. DOMAINS — Unstoppable + Vercel
# Vault: integrations/unstoppable, integrations/vercel, domains/runtime
# =============================================================================
UD_API_KEY=REPLACE_FROM_VAULT
VERCEL_API_TOKEN=REPLACE_FROM_VAULT
# VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/...

# =============================================================================
# 7. IPFS / yieldswarm.blockchain
# Vault: integrations/pinata
# =============================================================================
PINATA_API_KEY=REPLACE_FROM_VAULT
PINATA_SECRET=REPLACE_FROM_VAULT
PINATA_JWT=REPLACE_FROM_VAULT

# =============================================================================
# 8. LLM ROUTER (Odysseus + LiteLLM)
# Vault: runtime/llm, runtime/odysseus
# =============================================================================
APP_BIND=127.0.0.1
APP_PORT=7000
AUTH_ENABLED=true
LLM_ROUTER_BIND=127.0.0.1
LLM_ROUTER_PORT=4000
YIELDSWARM_EMBEDDING_MODEL=akash-ollama-embed
OPENROUTER_API_KEY=REPLACE_FROM_VAULT
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
FIREWORKS_API_KEY=REPLACE_FROM_VAULT
OPENAI_API_KEY=REPLACE_FROM_VAULT
ANTHROPIC_API_KEY=REPLACE_FROM_VAULT
GROK_API_KEY=REPLACE_FROM_VAULT
GEMINI_API_KEY=REPLACE_FROM_VAULT
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=CHANGE_ON_FIRST_BOOT

# =============================================================================
# 9. CORE SECURITY (Vault: runtime/core, runtime/wallets)
# =============================================================================
KIMICLAW_CONSENSUS_KEY=REPLACE_FROM_VAULT
WALLET_ENCRYPTION_KEY=REPLACE_FROM_VAULT
TEE_SIGNING_KEY=REPLACE_FROM_VAULT
DATABASE_ENCRYPTION_KEY=REPLACE_FROM_VAULT
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# =============================================================================
# 10. HELIX + SOVEREIGN LOOPS
# =============================================================================
HELIX_CHAIN_ENABLED=1
GREEK_LAYER__ACCESS_CONTROL_ENABLED=true
GREEK_LAYER__STRICT_SANITIZATION=true
EASTERN_LAYER__FEEDBACK_ENABLED=true
ZK__VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000

# =============================================================================
# 11. MINING + AKASH GPU (see deploy/akash.env for deploy-specific vars)
# =============================================================================
MINING_DRY_RUN=0
MINING_AUTO_START=0
BT_NETUID=1
BT_NETWORK=finney
BT_WALLET_NAME=miner
BT_HOTKEY_NAME=default
DEPLOY_SDL=deploy/akash-bittensor-miner.sdl.yml
DEPLOY_IMAGE=ghcr.io/yield-swarm/bittensor-miner:latest
AKASH_KEY_NAME=yieldswarm
AKASH_CHAIN_ID=akashnet-2
AKASH_NODE=https://rpc.akashnet.net:443
AKASH_AUTH_MODE=jwt
AKASH_GAS=auto
AKASH_GAS_ADJUSTMENT=1.5
AKASH_GAS_PRICES=0.025uakt
AKASH_GPU_MODEL=rtx3090
AKASH_MAX_BID_PRICE=700000
AUTO_SELECT_BID=1
AKASH_ACCOUNT_ADDRESS=akash1REPLACE_WITH_YOUR_ADDRESS
VAULT_AKASH_ROLE=bittensor-runtime

# Payout wallets (public — keys in Vault mining/wallets)
MINING_ROOT_TAO=5GwCZMWxtmkjpMzA7p1EFynRFicebo8FNjjqoVugxNMkSQSF
NEXUS_TREASURY_SOLANA=kuTcpVPbdC8oYB6gkT2s5tZKzsBsG1hHe7C9zhRpXSN

# =============================================================================
# 12. PAYMENTS (public client keys only in .env — secrets in Vault)
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE
NEXT_PUBLIC_PLATFORM_FEE_RATE=0.01
NEXT_PUBLIC_SQUARE_ENVIRONMENT=production
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=REPLACE

# =============================================================================
# 13. TELEGRAM / SOCIAL
# Vault: integrations/telegram
# =============================================================================
TELEGRAM_BOT_TOKEN=REPLACE_FROM_VAULT
# TELEGRAM_YIELDSWARM_CHAT_ID=REPLACE   # add to Vault when broadcasting

# =============================================================================
# 15. AWS TON SETTLE ENGINE (us-west-2) — Vercel TMA backend
# =============================================================================
AWS_REGION=us-west-2
NEXT_PUBLIC_TON_SETTLE_API_URL=https://YOUR_API_ID.execute-api.us-west-2.amazonaws.com/production/api/claim
PLAYER_SBT_CONTRACT=EQ_REPLACE_WITH_PLAYER_SBT_ADDRESS
TON_SETTLE_CORS_ORIGIN=https://yieldswarm.crypto
# Redis + secrets provisioned by SAM template — not in .env
# REDIS_HOST=  # ElastiCache primary — Lambda env only
# SECRETS_ARN= # Secrets Manager ARN for SERVER_ED25519_PRIVATE_KEY

MONITORING_PROMETHEUS_URL=http://127.0.0.1:9090
ERROR_WEBHOOK=REPLACE_FROM_VAULT
BUG_BOUNTY_AGENT_ENABLED=true
