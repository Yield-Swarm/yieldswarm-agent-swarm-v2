# GPU pool — cheap consumer RTX under $0.40/hr (Azure + Akash + Vast + RunPod)
# Copy: cp deploy/env/gpu-pool.env.example deploy/env/gpu-pool.env

GPU_POOL_BUDGET_USD=300
GPU_MAX_PRICE_PER_HOUR=0.40
GPU_TARGET_MODELS=RTX_3060,RTX_3070,RTX_3080,RTX_3090,RTX_4060,RTX_4070,RTX_4080,RTX_4090

# Provider daily caps (stay inside Cherry 90-day + Azure credits)
MULTICLOUD_AKASH_MAX_AKT=5
MULTICLOUD_VAST_MAX_USD=150
MULTICLOUD_RUNPOD_MAX_USD=100
MULTICLOUD_AZURE_MAX_USD=50

# Akash
AKASH_KEY_NAME=yieldswarm
AKASH_MAX_BID_PRICE=400000
AUTO_SELECT_BID=1

# API keys (or load from Vault)
VAST_API_KEY=
RUNPOD_API_KEY=

# Dry-run by default — set GPU_POOL_DRY_RUN=0 to launch
GPU_POOL_DRY_RUN=1
