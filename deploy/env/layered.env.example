# ============================================
# YIELDSWARM - LAYERED ENVIRONMENT VARIABLES
# ============================================
# Copy to repo root:  cp deploy/env/layered.env.example .env
# Full catalog:       docs/ENV_VARS.md
# Vault migration:    docs/VAULT_ENV_INJECTION.md
# Never commit real secrets.

# --- D¹ Greek Layer (Security & Isolation) ---
GREEK_LAYER__ACCESS_CONTROL_ENABLED=true
GREEK_LAYER__MAX_CONTEXT_WINDOW=32
GREEK_LAYER__STRICT_SANITIZATION=true
NETWORK_LOCKDOWN_MODE=true
SESSION_SECRET=replace_with_long_random_session_secret

# --- E¹ Eastern Layer (Flow & Feedback) ---
EASTERN_LAYER__FEEDBACK_ENABLED=true
EASTERN_LAYER__RECURSIVE_ROUTING=true
YIELDSWARM_TELEMETRY_REFRESH_MS=30000

# --- Z¹ Entropy / ZK Layer ---
ZK__CIRCUIT_WASM_PATH=./circuits/build/entropy_proof_js/entropy_proof.wasm
ZK__ZKEY_PATH=./circuits/build/entropy_proof_final.zkey
ZK__VKEY_PATH=./circuits/build/verification_key.json
ZK__VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000
MUTATION_CONTROLLER_ADDRESS=
YIELDSWARM_NFT_ADDRESS=

# --- W Rosetta i18n ---
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,zh,hi,es,ar,fr,ja,de

# --- HashiCorp Vault (source of truth in production) ---
VAULT_ADDR=https://vault.example.com
VAULT_NAMESPACE=
VAULT_AUTH_METHOD=approle
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_KV_MOUNT=yieldswarm
VAULT_INJECT_RUNTIME_SECRETS=auto
USE_VAULT_AKASH=true

# --- LLM Routing Layer (18 APIs) ---
LLM__ROUTER_TYPE=odysseus
LLM__DEFAULT_MODEL=Razer-70B
LLM_ROUTER_BIND=127.0.0.1
LLM_ROUTER_PORT=4000
YIELDSWARM_ROUTER_API_KEY=replace_with_long_random_router_key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
COHERE_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
AI21_API_KEY=
HUGGINGFACE_API_KEY=
REPLICATE_API_TOKEN=
ANYSCALE_API_KEY=
GROQ_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
GOOGLE_AI_API_KEY=

# --- Multi-Cloud Infrastructure (18 providers) ---
AKASH_OWNER_ADDRESS=
AKASH_KEY_NAME=
AKASH_CONSOLE_API=https://console-api.akash.network/v1
RUNPOD_API_KEY=
VAST_API_KEY=
VULTR_API_KEY=
DIGITALOCEAN_TOKEN=
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
HETZNER_API_TOKEN=
FLY_API_TOKEN=
RENDER_API_KEY=
RAILWAY_TOKEN=
LINODE_TOKEN=
SCALEWAY_ACCESS_KEY=
SCALEWAY_SECRET_KEY=
ORACLE_CLOUD_TENANCY=
ORACLE_CLOUD_USER=
ORACLE_CLOUD_FINGERPRINT=
ORACLE_CLOUD_PRIVATE_KEY_PATH=

# --- TON + Kairo Layer ---
TON_API_KEY=
TON_MINI_GAME_CONTRACT=
TON_NETWORK=mainnet
KAIRO_TELEMETRY_ENDPOINT=http://127.0.0.1:8080/api/kairo/telemetry
MAPBOX_TOKEN=
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_FLEET_API_URL=https://fleet-api.prd.na.vn.cloud.tesla.com

# --- Database & Storage ---
NEON_DATABASE_URL=
DATABASE_URL=
IPFS_API_KEY=
IPFS_GATEWAY=https://ipfs.io
PINATA_API_KEY=
PINATA_SECRET=
PINATA_JWT=
ARWEAVE_KEY=
FILECOIN_STORAGE_KEY=

# --- Blockchain RPC ---
SOLANA_RPC_URL=
ETHEREUM_RPC_URL=
HELIUS_API_KEY=
INFURA_PROJECT_ID=
INFURA_API_KEY=
ANKR_API_KEY=
QUICKNODE_API_KEY=
ALCHEMY_API_KEY=

# --- yieldswarm.blockchain IPFS + Telegram §6 ---
# See docs/IPFS_YIELDSWARM_BLOCKCHAIN.md
TELEGRAM_BOT_TOKEN=
TELEGRAM_YIELDSWARM_CHAT_ID=
TELEGRAM_COUNCIL_CHAT_ID=
YIELDSWARM_BLOCKCHAIN_CID=
HELIX_DEPLOY_RECEIPT=
SKIP_TELEGRAM_BROADCAST=0
SKIP_IPFS_VERIFY=0

# --- Monitoring & Observability ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
DATADOG_API_KEY=
DATADOG_SITE=datadoghq.com
MONITORING_PROMETHEUS_URL=http://127.0.0.1:9090
LOG_LEVEL=INFO

# --- Payments (Vercel / Portal — not Akash) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
SQUARE_ACCESS_TOKEN=
WISE_API_TOKEN=

# --- Deploy targets ---
TARGET_ENV=devnet
API_BASE=http://127.0.0.1:8080
BACKEND_IMAGE=ghcr.io/yieldswarm/yieldswarm-backend:latest
ODYSSEUS_IMAGE=ghcr.io/yieldswarm/odysseus:main
DEPLOY_IMAGE=

# --- Hardware guardian (entrypoint.monitor.sh) ---
METRICS_URL=http://127.0.0.1:8000/metrics
VRAM_MAX_BYTES=31677329408
TEMP_THRESHOLD_CELSIUS=83
