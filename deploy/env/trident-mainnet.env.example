# Poseidon Delta Trident — mainnet environment template
# Copy: cp deploy/env/trident-mainnet.env.example deploy/env/trident-mainnet.env
# Load: set -a && source deploy/env/trident-mainnet.env && set +a

NODE_ENV=mainnet
TRIDENT_VERSION=3.05911111100
SYSTEM_CLOCK_TICK_RATE=5000

# --- Node identity (auto-set by poseidon-deploy if unset) ---
MINING_NODE_ID=
POSEIDON_MODE=edge

# --- Unstoppable Domains + routing ---
UD_API_KEY=
UD_API_BASE=https://api.unstoppabledomains.com
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
ROOT_DOMAIN=yieldswarm.crypto

# --- DePIN vehicle telemetry ---
HELIOM_EDGE_INGEST_KEY=
VEHICLE_ID=APOLLO_NEXUS_TEST_01
HELIXPOW_INGEST_URL=https://helixpow.pw/api/iot/telemetry

# --- Mining (set MINING_DRY_RUN=0 to launch xmrig) ---
LOLMINER_LOCAL_PORT=4067
MINING_DRY_RUN=1
MINING_PAYOUT_ASSET=LTC
MINING_POOL_URL=rx.unmineable.com:3333
WALLET_XMR=
WALLET_KAS=
WALLET_ZEN=
WALLET_ZEPH=
WALLET_PYI=
WALLET_PRL=
WALLET_LTC=
WALLET_DOGE=
WALLET_BASE_RUNIC=

# --- Coinbase CDP ---
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
COINBASE_CREDIT_LIMIT_USD=6000

# --- Azure VMSS mining burst ---
AZURE_VMSS_COUNT=10

# --- Codex CDN ---
CODEX_INGEST_URL=https://yslrcodex.com/api/ingest
CODEX_PUSH_ENABLED=1

# --- Treasury on-chain ---
TREASURY_EVM_ADDRESS=0x9505578Bd5b32468E3cEa632664F7b8d2e46128c
NEXUS_TREASURY_SOLANA=kuTcpVPbdC8oYB6gkT2s5tZKzsBsG1hHe7C9zhRpXSN

# --- Akash / backend ingress ---
AKASH_KEY_NAME=
AKASH_ACCOUNT_ADDRESS=
AKASH_WORKER_HOST=
PORT=8080

# --- Vault ---
VAULT_ADDR=https://vault.yieldswarm.io:8200
VAULT_TOKEN=

# --- EVM deploy ---
MAINNET_RPC_URL=
ETHEREUM_RPC_URL=
BASE_RPC_URL=
AVAX_RPC_URL=
AVALANCHE_RPC_URL=
DEPLOYER_PRIVATE_KEY=
KAIROS_GOVERNANCE_ADDRESS=

# --- Helix duadilateral chain RPCs ---
NEXUS_CHAIN_URL=http://127.0.0.1:8080/api/helix
HELIX_CHAIN_URL=http://127.0.0.1:8080/api/helix
SHADOW_CHAIN_URL=http://127.0.0.1:8080/api/arena/overview
TON_RPC_URL=https://tonapi.io
TON_API_KEY=
BITTENSOR_RPC_URL=https://entrypoint-finney.opentensor.ai:443
TAO_RPC_URL=
TREASURY_TON_ADDRESS=
TREASURY_TAO_ADDRESS=
TREASURY_AVAX_ADDRESS=
TREASURY_BASE_ADDRESS=
