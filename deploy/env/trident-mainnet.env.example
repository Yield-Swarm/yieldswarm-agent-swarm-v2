# Poseidon Delta Trident v3.05911111100 — Mainnet environment template
# Copy: cp deploy/env/trident-mainnet.env.example deploy/env/trident-mainnet.env
# Load: set -a && source deploy/env/trident-mainnet.env && set +a

NODE_ENV=mainnet
TRIDENT_VERSION=3.05911111100
SYSTEM_CLOCK_TICK_RATE=5000

# --- Unstoppable Domains + routing ---
UD_API_KEY=
UD_API_BASE=https://api.unstoppabledomains.com
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
ROOT_DOMAIN=yieldswarm.crypto

# --- DePIN vehicle telemetry (Worker 1 Sentinel) ---
HELIOM_EDGE_INGEST_KEY=
VEHICLE_ID=APOLLO_NEXUS_TEST_01
HELIXPOW_INGEST_URL=https://helixpow.pw/api/iot/telemetry

# --- Mining (Worker 2 Nexus) ---
LOLMINER_LOCAL_PORT=4067
MINING_DRY_RUN=1
MINING_PAYOUT_ASSET=LTC
MINING_POOL_URL=rx.unmineable.com:3333
# PoW wallet destinations (Unmineable auto-exchange or native pools)
WALLET_XMR=
WALLET_KAS=
WALLET_ZEN=
WALLET_ZEPH=
WALLET_PYI=
WALLET_PRL=
WALLET_LTC=
WALLET_DOGE=
WALLET_BASE_RUNIC=

# --- Coinbase CDP (swarm portfolio) ---
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
COINBASE_CREDIT_LIMIT_USD=6000
COINBASE_MARGIN_ENABLED=0
COINBASE_TRADING_ENABLED=0

# --- Azure VMSS mining burst ---
AZURE_VMSS_COUNT=10

# --- Codex CDN (Worker 5) ---
CODEX_INGEST_URL=https://yslrcodex.com/api/ingest
CODEX_PUSH_ENABLED=1

# --- Treasury on-chain targets ---
TREASURY_EVM_ADDRESS=0x9505578Bd5b32468E3cEa632664F7b8d2e46128c
NEXUS_TREASURY_SOLANA=kuTcpVPbdC8oYB6gkT2s5tZKzsBsG1hHe7C9zhRpXSN

# --- Akash / backend ingress ---
AKASH_WORKER_HOST=
PORT=8080

# --- Vault (load secrets at deploy) ---
VAULT_ADDR=https://vault.yieldswarm.io:8200
VAULT_TOKEN=

# --- EVM deploy ---
MAINNET_RPC_URL=
DEPLOYER_PRIVATE_KEY=
KAIROS_GOVERNANCE_ADDRESS=

# --- Azure VM SSH ---
AZURE_ADMIN_USERNAME=azureuser
AZURE_SSH_KEY_NAME=yieldswarm-deploy-key
# AZURE_SSH_PUBLIC_KEY=ssh-ed25519 AAAA... yieldswarm-azure
# AZURE_VM_NAME=yieldswarm-vm
