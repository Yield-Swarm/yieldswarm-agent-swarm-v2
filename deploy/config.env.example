# =============================================================================
# YieldSwarm AgentSwarm OS — Production Deployment Configuration
# =============================================================================
# Copy to deploy/config.env and fill in real values, then `source` it (the
# Makefile and deploy.sh load it automatically if present).
#
#   cp deploy/config.env.example deploy/config.env
#   $EDITOR deploy/config.env
#
# NOTE: deploy/config.env is git-ignored. Never commit real secrets.
# Application secrets (API keys, wallet keys) live in the root .env — see
# .env.example. This file holds *deployment/infra* settings only.
# =============================================================================

# ---------------------------------------------------------------------------
# 1. Container registry (GitHub Container Registry / GHCR)
# ---------------------------------------------------------------------------
# GHCR owner is your GitHub user or org (lowercase).
GHCR_OWNER=your-github-username
# Image namespace prefix (images are pushed as ghcr.io/$GHCR_OWNER/$IMAGE_PREFIX-<component>)
IMAGE_PREFIX=yieldswarm
# Image tag. Defaults to the short git SHA when unset.
IMAGE_TAG=
# PAT or GITHUB_TOKEN with `write:packages`. In CI this is provided automatically.
GHCR_TOKEN=
# GitHub username used for `docker login ghcr.io` (usually same as GHCR_OWNER).
GHCR_USER=

# ---------------------------------------------------------------------------
# 2. Akash Network (decentralized compute leases)
# ---------------------------------------------------------------------------
# Akash wallet key name (created via `akash keys add` / imported).
AKASH_KEY_NAME=yieldswarm
AKASH_KEYRING_BACKEND=test
# Auth: keyring (default) or jwt — see docs/AKASH_AUTH.md
# AKASH_AUTH_METHOD=keyring
# AKASH_JWT=eyJ...   # optional; for CI manifest sends
# Akash chain + node.
AKASH_CHAIN_ID=akashnet-2
AKASH_NODE=https://rpc.akashnet.net:443
AKASH_GAS=auto
AKASH_GAS_ADJUSTMENT=1.5
AKASH_GAS_PRICES=0.025uakt
# Path to the SDL manifest used for the lease.
AKASH_SDL=deploy/akash/deploy.sdl.yaml
# Auto-heal: minimum AKT balance (uakt) before the loop tops up / re-bids.
AKASH_MIN_BALANCE_UAKT=5000000
# Auto-heal poll interval (seconds).
AKASH_HEAL_INTERVAL=60

# ---------------------------------------------------------------------------
# 3. Terraform multi-cloud fallback
# ---------------------------------------------------------------------------
TF_DIR=deploy/terraform
# Toggle each cloud on/off (true/false). Akash is primary; these are fallbacks.
TF_ENABLE_FLY=false
TF_ENABLE_RENDER=false
TF_ENABLE_HETZNER=false
# Provider credentials (only needed if the matching TF_ENABLE_* is true).
FLY_API_TOKEN=
RENDER_API_KEY=
HCLOUD_TOKEN=

# ---------------------------------------------------------------------------
# 4. Frontend / worker wiring
# ---------------------------------------------------------------------------
# Where the generated runtime config is written (consumed by the dashboard).
FRONTEND_CONFIG_OUT=dashboard/config.js
# Override the worker URL detection. Comma-separated list of https URLs.
# If empty, deploy.sh derives these from the Akash lease + Terraform outputs.
WORKER_URLS=
# Vercel project (frontend host) — used for the optional redeploy hook.
VERCEL_DEPLOY_HOOK=

# ---------------------------------------------------------------------------
# 5. Monitoring + sovereign loops
# ---------------------------------------------------------------------------
MONITORING_COMPOSE=deploy/monitoring/docker-compose.yml
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
# Sovereign loop cadence (seconds between swarm consensus ticks).
SOVEREIGN_LOOP_INTERVAL=900
# Directory for runtime PIDs / logs.
RUN_DIR=.run
