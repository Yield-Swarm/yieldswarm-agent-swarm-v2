# YieldSwarm BERT / vLLM worker — RTX 5090 cluster with AWQ quantization.
# Paradigm Shift bare-metal scaling layer.
#
# Build:
#   docker build -f deploy/Dockerfile.bert -t yieldswarm-bert:latest .
#
# Run:
#   docker run --gpus all -p 8000:8000 \
#     -e MODEL_ID=meta-llama/Llama-3.1-8B-Instruct-AWQ \
#     -e MAX_MODEL_LEN=8192 \
#     yieldswarm-bert:latest

FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

LABEL org.opencontainers.image.title="yieldswarm-bert-vllm" \
      org.opencontainers.image.description="vLLM continuous-batching AWQ inference for RTX 5090 cluster"

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    MODEL_ID=meta-llama/Llama-3.1-8B-Instruct-AWQ \
    QUANTIZATION=awq \
    MAX_MODEL_LEN=8192 \
    GPU_MEMORY_UTILIZATION=0.92 \
    TENSOR_PARALLEL_SIZE=1 \
    VLLM_PORT=8000 \
    HF_HOME=/cache/huggingface

RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 python3-pip python3-venv curl tini \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --no-cache-dir --upgrade pip \
    && python3 -m pip install --no-cache-dir \
      "vllm>=0.6.0" \
      "torch>=2.4.0" \
      "transformers>=4.44.0" \
      "accelerate>=0.33.0"

WORKDIR /app
COPY deploy/entrypoint.bert.sh /app/entrypoint.bert.sh
RUN chmod +x /app/entrypoint.bert.sh

RUN mkdir -p /cache/huggingface && useradd -m -u 10001 vllm && chown -R vllm:vllm /app /cache
USER vllm

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
  CMD curl -sf "http://127.0.0.1:${VLLM_PORT}/health" || exit 1

ENTRYPOINT ["/usr/bin/tini", "--", "/app/entrypoint.bert.sh"]
