# YieldSwarm integration backend — Akash image with Vault secret injection.
# Build: docker build -f backend/Dockerfile.akash -t ghcr.io/yieldswarm/yieldswarm-backend:latest .

FROM node:20-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 python3-pip ca-certificates curl \
  && rm -rf /var/lib/apt/lists/* \
  && pip3 install --no-cache-dir --break-system-packages "hvac>=2.1.0"

WORKDIR /app

COPY backend/package.json backend/package-lock.json ./backend/
RUN cd backend && npm ci --omit=dev

COPY backend/ ./backend/
COPY lib/ ./lib/
COPY frontend/ ./frontend/
COPY dashboard/ ./dashboard/
COPY council/ ./council/
COPY scripts/vault-export-env.py ./scripts/

RUN chmod +x /app/backend/entrypoint-akash.sh \
  && mkdir -p /run/secrets

ENV NODE_ENV=production \
    PORT=8080 \
    HOST=0.0.0.0

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD curl -sf "http://127.0.0.1:${PORT}/api/health" || exit 1

ENTRYPOINT ["/app/backend/entrypoint-akash.sh"]
