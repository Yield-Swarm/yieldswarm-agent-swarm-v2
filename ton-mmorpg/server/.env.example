# TON MMORPG server — copy to .env (never commit)
PORT=3100
NODE_ENV=development

# TON JSON-RPC (Toncenter or own node)
TONCENTER_API_KEY=your_toncenter_key_here
TON_RPC_ENDPOINT=https://toncenter.com/api/v2/jsonRPC

# Deployed contracts (testnet first)
PLAYER_SBT_ADDRESS=
IGJ_MASTER_ADDRESS=

# Sync security
MAX_DELTA_T_SECONDS=3600
SESSION_TTL_SECONDS=86400
SYNC_API_SECRET=generate_long_random_secret

# PoE caps (nano units — use scientific notation strings, e.g. 1e9)
POE_NANO_CAP_PER_SYNC=1e9
POE_IGJ_CAP_PER_SYNC=1e12
POE_NANO_PER_SECOND=1e6

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Optional Upstash Redis for distributed limits
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
